<?xml version="1.0" encoding="UTF-8"?>
<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/xml-screen-3.xsd" default-menu-title="Rule Sets">

    <transition name="createRuleSet">
        <service-call name="create#darpan.rule.RuleSet"/>
        <default-response url="."/>
    </transition>
    <transition name="updateRuleSet">
        <service-call name="update#darpan.rule.RuleSet"/>
        <default-response url="."/>
    </transition>
    <transition name="deleteRuleSet">
        <service-call name="delete#darpan.rule.RuleSet"/>
        <default-response url="."/>
    </transition>
    <transition name="editRuleSet">
        <default-response url="../RuleSetDetail"/>
    </transition>

    <actions>
        <entity-find entity-name="darpan.rule.RuleSet" list="ruleSetList">
            <search-form-inputs default-order-by="ruleSetId"/>
        </entity-find>
    </actions>

    <widgets>
        <container-box>
            <box-header title="Manage Rule Sets"/>
            <box-body>
                <container-row>
                    <container-col md="12">
                        <link url="../RuleEngineTest" text="Run Verification Test" btn-type="primary"/>
                    </container-col>
                </container-row>
                <form-list name="RuleSetList" list="ruleSetList" transition="updateRuleSet">
                    <field name="ruleSetId">
                        <header-field show-order-by="true"/>
                        <default-field>
                            <link url="editRuleSet" text="${ruleSetId}" link-type="anchor"/>
                        </default-field>
                    </field>
                    <field name="ruleSetName">
                        <header-field show-order-by="true"/>
                        <default-field>
                            <text-line size="30"/>
                        </default-field>
                    </field>
                    <field name="description">
                        <default-field>
                            <text-line size="50"/>
                        </default-field>
                    </field>
                    <field name="version">
                        <default-field>
                            <text-line size="10"/>
                        </default-field>
                    </field>
                    <field name="lastUpdatedDate">
                        <header-field show-order-by="true"/>
                        <default-field>
                            <display/>
                        </default-field>
                    </field>
                    <field name="submitButton">
                        <header-field title="Update"/>
                        <default-field>
                            <submit/>
                        </default-field>
                    </field>
                    <field name="deleteButton">
                        <header-field title="Delete"/>
                        <default-field>
                            <link url="deleteRuleSet" text="Delete" confirmation="Are you sure?"/>
                        </default-field>
                    </field>
                </form-list>
            </box-body>
        </container-box>

        <container-box>
            <box-header title="Create Rule Set"/>
            <box-body>
                <form-single name="CreateRuleSet" transition="createRuleSet">
                    <field name="ruleSetId">
                        <default-field>
                            <text-line size="20"/>
                        </default-field>
                    </field>
                    <field name="ruleSetName">
                        <default-field>
                            <text-line size="30"/>
                        </default-field>
                    </field>
                    <field name="description">
                        <default-field>
                            <text-line size="60"/>
                        </default-field>
                    </field>
                    <field name="version">
                        <default-field>
                            <text-line size="10" default-value="1.0"/>
                        </default-field>
                    </field>
                    <field name="submitButton">
                        <default-field>
                            <submit text="Create"/>
                        </default-field>
                    </field>
                </form-single>
            </box-body>
        </container-box>
    </widgets>
</screen>
