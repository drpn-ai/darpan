<?xml version="1.0" encoding="UTF-8"?>
<entities xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/entity-definition-3.xsd">

    <!-- ========================================================= -->
    <!-- darpan.party -->
    <!-- ========================================================= -->

    <entity entity-name="PartyType" package="darpan.party" use="configuration">
        <description>Defines the type of party (person, organization, etc).</description>
        <field name="partyTypeId" type="id" is-pk="true"/>
        <field name="description" type="text-medium"/>
    </entity>

    <entity entity-name="Party" package="darpan.party" use="configuration">
        <description>Base party record for a person or organization.</description>
        <field name="partyId" type="id" is-pk="true"/>
        <field name="partyTypeId" type="id"/>
        <field name="partyName" type="text-medium"/>

        <relationship type="one" related="darpan.party.PartyType">
            <key-map field-name="partyTypeId"/></relationship>
        <relationship type="one" related="darpan.party.Person" short-alias="person">
            <key-map field-name="partyId"/></relationship>
        <relationship type="one" related="darpan.party.Organization" short-alias="organization">
            <key-map field-name="partyId"/></relationship>
    </entity>

    <entity entity-name="Person" package="darpan.party" use="configuration">
        <description>Person-specific details for a party.</description>
        <field name="partyId" type="id" is-pk="true"/>
        <field name="firstName" type="text-medium"/>
        <field name="lastName" type="text-medium"/>

        <relationship type="one" related="darpan.party.Party">
            <key-map field-name="partyId"/></relationship>
    </entity>

    <entity entity-name="Organization" package="darpan.party" use="configuration">
        <description>Organization-specific details for a party.</description>
        <field name="partyId" type="id" is-pk="true"/>
        <field name="organizationName" type="text-medium"/>

        <relationship type="one" related="darpan.party.Party">
            <key-map field-name="partyId"/></relationship>
    </entity>

    <!-- ========================================================= -->
    <!-- darpan.reconciliation -->
    <!-- ========================================================= -->

    <entity entity-name="Reconciliation" package="darpan.reconciliation" use="configuration">
        <description>Schedulable grouping of reconciliation runs scoped to a party.</description>
        <field name="reconciliationId" type="id" is-pk="true"/>
        <field name="reconciliationName" type="text-medium"/>
        <field name="description" type="text-medium"/>
        <field name="scheduleExpr" type="text-medium"/>
        <field name="partyId" type="id"/>
        <field name="isActive" type="text-indicator"/>

        <relationship type="one" related="darpan.party.Party">
            <key-map field-name="partyId"/></relationship>
        <relationship type="many" related="darpan.reconciliation.ReconciliationRun" short-alias="runs">
            <key-map field-name="reconciliationId"/></relationship>
    </entity>

    <entity entity-name="ReconciliationRun" package="darpan.reconciliation" use="configuration">
        <description>Atomic reconciliation check within a reconciliation.</description>
        <field name="reconciliationRunId" type="id" is-pk="true"/>
        <field name="reconciliationId" type="id"/>
        <field name="runName" type="text-medium"/>
        <field name="dataDomain" type="text-short"/>
        <field name="purpose" type="text-short"/>
        <field name="defaultTimeWindow" type="text-short"/>
        <field name="ruleSetId" type="id"/>
        <field name="runSequence" type="number-integer"/>

        <relationship type="one" related="darpan.reconciliation.Reconciliation">
            <key-map field-name="reconciliationId"/></relationship>
        <relationship type="one" related="darpan.reconciliation.RuleSet">
            <key-map field-name="ruleSetId"/></relationship>
        <relationship type="many" related="darpan.reconciliation.RunDataDocument" short-alias="dataDocuments">
            <key-map field-name="reconciliationRunId"/></relationship>
        <relationship type="many" related="darpan.reconciliation.RunSystemInstance" short-alias="systemInstances">
            <key-map field-name="reconciliationRunId"/></relationship>
    </entity>

    <entity entity-name="RunDataDocument" package="darpan.reconciliation" use="configuration">
        <description>Associates DataDocuments with a reconciliation run.</description>
        <field name="reconciliationRunId" type="id" is-pk="true"/>
        <field name="dataDocumentId" type="id" is-pk="true"/>
        <field name="filterExpression" type="text-long"/>
        <field name="aggregation" type="text-medium"/>
        <field name="isRequired" type="text-indicator"/>

        <relationship type="one" related="darpan.reconciliation.ReconciliationRun">
            <key-map field-name="reconciliationRunId"/></relationship>
        <relationship type="one" related="moqui.entity.document.DataDocument">
            <key-map field-name="dataDocumentId"/></relationship>
    </entity>

    <entity entity-name="RunSystemInstance" package="darpan.reconciliation" use="configuration">
        <description>Associates systems with a reconciliation run.</description>
        <field name="reconciliationRunId" type="id" is-pk="true"/>
        <field name="systemMessageRemoteId" type="id" is-pk="true"/>
        <field name="role" type="text-short"/>

        <relationship type="one" related="darpan.reconciliation.ReconciliationRun">
            <key-map field-name="reconciliationRunId"/></relationship>
        <relationship type="one" related="moqui.service.message.SystemMessageRemote">
            <key-map field-name="systemMessageRemoteId"/></relationship>
    </entity>

    <entity entity-name="RuleSet" package="darpan.reconciliation" use="configuration">
        <description>Rule set to evaluate reconciliation outcomes.</description>
        <field name="ruleSetId" type="id" is-pk="true"/>
        <field name="name" type="text-medium"/>
        <field name="version" type="text-short"/>

        <relationship type="many" related="darpan.reconciliation.Rule" short-alias="rules">
            <key-map field-name="ruleSetId"/></relationship>
    </entity>

    <entity entity-name="Rule" package="darpan.reconciliation" use="configuration">
        <description>Single rule within a rule set.</description>
        <field name="ruleId" type="id" is-pk="true"/>
        <field name="ruleSetId" type="id"/>
        <field name="ruleType" type="text-short"/>
        <field name="expression" type="text-long"/>
        <field name="severity" type="text-short"/>

        <relationship type="one" related="darpan.reconciliation.RuleSet">
            <key-map field-name="ruleSetId"/></relationship>
    </entity>

    <!-- ========================================================= -->
    <!-- darpan.mapping -->
    <!-- ========================================================= -->

    <entity entity-name="ReconciliationMapping" package="darpan.mapping" use="configuration">
        <description>Named mapping definition for source field values by system.</description>
        <field name="reconciliationMappingId" type="id" is-pk="true"/>
        <field name="mappingName" type="text-short" not-null="true"/>
        <field name="description" type="text-medium"/>
        <field name="createdDate" type="date-time"/>
        <field name="lastUpdatedDate" type="date-time"/>
    </entity>

    <entity entity-name="ReconciliationMappingMember" package="darpan.mapping" use="configuration">
        <description>Mapping entry that binds a source field/value to a system.</description>
        <field name="mappingMemberId" type="id" is-pk="true"/>
        <field name="reconciliationMappingId" type="id" not-null="true"/>
        <field name="systemEnumId" type="id" not-null="true"/>
        <field name="systemFieldName" type="text-medium" not-null="true"/>
        <field name="createdDate" type="date-time"/>

        <relationship type="one" related="darpan.mapping.ReconciliationMapping" fk-name="MAPMEM_MAPDEF">
            <key-map field-name="reconciliationMappingId"/></relationship>
        <relationship type="one" related="moqui.basic.Enumeration" fk-name="MAPMEM_SYS_ENUM">
            <key-map field-name="systemEnumId" related-field-name="enumId"/></relationship>
    </entity>
</entities>
