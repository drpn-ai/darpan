<?xml version="1.0" encoding="UTF-8"?>
<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/xml-screen-3.xsd"
        default-menu-title="JSON Schema Manager"
        require-authentication="true">

    <subscreens default-item="Browse">
        <subscreens-item name="Browse" location="component://darpan/screen/Reconciliation/JsonSchema/JsonSchemaBrowse.xml"/>
        <subscreens-item name="Wizard" location="component://darpan/screen/Reconciliation/JsonSchema/JsonSchemaWizard.xml"/>
        <subscreens-item name="Editor" location="component://darpan/screen/Reconciliation/JsonSchema/JsonSchemaEditor.xml" menu-include="false"/>
    </subscreens>
    <pre-actions>
        <if condition="!darpan.facade.common.PilotAccessSupport.isSuperAdmin(ec)">
            <return error="true" message="Pilot administration screens are restricted to super-admin users."/>
        </if>
    </pre-actions>

    <widgets>
        <subscreens-active/>
    </widgets>
</screen>
