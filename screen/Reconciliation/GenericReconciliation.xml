<?xml version="1.0" encoding="UTF-8"?>
<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/xml-screen-3.xsd"
        default-menu-title="File Reconciliation"
        require-authentication="true">
    <subscreens default-item="Main">
        <subscreens-item name="Main" menu-include="false"
                location="component://darpan/screen/Reconciliation/GenericReconciliation/Main.xml"/>
        <subscreens-item name="GenericReconciliationView" menu-include="false"
                location="component://darpan/screen/Reconciliation/GenericReconciliation/GenericReconciliationView.xml"/>
    </subscreens>
    <pre-actions>
        <if condition="!darpan.facade.common.PilotAccessSupport.isSuperAdmin(ec)">
            <return error="true" message="Pilot administration screens are restricted to super-admin users."/>
        </if>
    </pre-actions>
    <widgets>
        <subscreens-active/>
    </widgets>
</screen>
