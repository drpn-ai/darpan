<?xml version="1.0" encoding="UTF-8"?>
<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/xml-screen-3.xsd" default-menu-title="Rule Set Detail">

    <parameter name="ruleSetId" required="true"/>

    <transition name="updateRuleSet">
        <service-call name="reconciliation.ReconciliationRuleEngineServices.save#RuleSet"/>
        <default-response url="."/>
    </transition>
    <transition name="createRule">
        <service-call name="reconciliation.ReconciliationRuleEngineServices.save#Rule"/>
        <default-response url="."/>
    </transition>
    <transition name="updateRule">
        <service-call name="reconciliation.ReconciliationRuleEngineServices.save#Rule"/>
        <default-response url="."/>
    </transition>
    <transition name="deleteRule">
        <service-call name="reconciliation.ReconciliationRuleEngineServices.delete#Rule"/>
        <default-response url="."/>
    </transition>

    <transition name="compileRuleSet">
        <service-call name="reconciliation.ReconciliationRuleEngineServices.compile#RuleSet" in-map="[ruleSetId:ruleSetId, forceRebuild:true]"/>
        <default-response url="."/>
    </transition>

    <transition name="testRules">
        <actions>
            <service-call name="reconciliation.ReconciliationRuleEngineServices.execute#RuleSetJson" in-map="[ruleSetId:ruleSetId, jsonData:jsonData, returnAllFacts:returnAllFacts]" out-map="testOut"/>
            <script><![CDATA[
                String sessionKey = "ruleEngineTestOut_" + ruleSetId
                boolean returnAll = false
                if (returnAllFacts instanceof Boolean) {
                    returnAll = (Boolean) returnAllFacts
                } else if (returnAllFacts != null) {
                    String raw = returnAllFacts.toString().trim().toLowerCase()
                    returnAll = ["y", "yes", "true", "1"].contains(raw)
                }
                Map sessionPayload = [
                        jsonData      : jsonData,
                        returnAllFacts: returnAll,
                        results       : (testOut.results ?: []),
                        matchedResults: (testOut.matchedResults ?: []),
                        warnings      : (testOut.warnings ?: []),
                        firedRuleCount: (testOut.firedRuleCount ?: 0),
                        ruleCount     : (testOut.ruleCount ?: 0),
                        error         : testOut.error
                ]
                ec.web.session.setAttribute(sessionKey, sessionPayload)
                if (testOut.error) {
                    ec.message.addError("Rule test failed: ${testOut.error}")
                } else {
                    int resultCount = ((testOut.results ?: []) as List).size()
                    ec.message.addMessage("Rule test completed. fired=${testOut.firedRuleCount ?: 0}, results=${resultCount}.")
                }
            ]]></script>
        </actions>
        <default-response url="."/>
    </transition>

    <transition name="clearTestResult">
        <actions>
            <script><![CDATA[
                ec.web.session.removeAttribute("ruleEngineTestOut_" + ruleSetId)
                ec.message.addMessage("Cleared test bench results.")
            ]]></script>
        </actions>
        <default-response url="."/>
    </transition>

    <actions>
        <entity-find-one entity-name="darpan.rule.RuleSet" value-field="ruleSet"/>
        <entity-find entity-name="darpan.rule.Rule" list="ruleList">
            <econdition field-name="ruleSetId"/>
            <order-by field-name="sequenceNum"/>
            <order-by field-name="ruleId"/>
        </entity-find>
        <script><![CDATA[
            String testKey = "ruleEngineTestOut_" + ruleSetId
            Map testOut = (Map) ec.web.session.getAttribute(testKey)
            testResultRows = (testOut?.results ?: []) as List
            testMatchedRows = (testOut?.matchedResults ?: []) as List
            testWarnings = (testOut?.warnings ?: []) as List
            testError = testOut?.error
            testFiredRuleCount = (testOut?.firedRuleCount ?: 0) as int
            testRuleCount = (testOut?.ruleCount ?: 0) as int
            testJsonData = testOut?.jsonData ?: '[{"id":1, "status":"Pending"}]'
            testReturnAllFacts = ((testOut?.returnAllFacts == true) ? "Y" : "N")
        ]]></script>
    </actions>

    <widgets>
        <container-box>
            <box-header title="Rule Set: ${ruleSet.ruleSetName} (${ruleSetId})"/>
            <box-body>
                <form-single name="RuleSetInfo" map="ruleSet" transition="updateRuleSet">
                    <field name="ruleSetId">
                        <default-field>
                            <display/>
                        </default-field>
                    </field>
                    <field name="ruleSetName">
                        <default-field>
                            <text-line size="40"/>
                        </default-field>
                    </field>
                    <field name="description">
                        <default-field>
                            <text-line size="60"/>
                        </default-field>
                    </field>
                    <field name="version">
                        <default-field>
                            <text-line size="10"/>
                        </default-field>
                    </field>
                    <field name="explosionPath">
                        <default-field>
                            <text-line size="40" placeholder="Optional JSONPath/list path for exploded items"/>
                        </default-field>
                    </field>
                    <field name="primaryKeyPath">
                        <default-field>
                            <text-line size="40" placeholder="Optional key path (for uniqueness or lookup)"/>
                        </default-field>
                    </field>
                    <field name="submitButton">
                        <default-field>
                            <submit text="Update"/>
                        </default-field>
                    </field>
                    <field name="compileButton">
                        <default-field>
                            <link url="compileRuleSet" text="Validate and Compile" btn-type="success" confirmation="Compile RuleSet with current active rules?"/>
                        </default-field>
                    </field>
                </form-single>
            </box-body>
        </container-box>

        <container-box>
            <box-header title="Test Bench"/>
            <box-body>
                <form-single name="TestRulesForm" transition="testRules" map="[ruleSetId:ruleSetId, jsonData:testJsonData, returnAllFacts:testReturnAllFacts]">
                    <field name="ruleSetId">
                        <default-field>
                            <hidden default-value="${ruleSetId}"/>
                        </default-field>
                    </field>
                    <field name="jsonData">
                        <default-field title="JSON Data Packet">
                            <text-area rows="6" cols="90" default-value="${testJsonData}"/>
                        </default-field>
                    </field>
                    <field name="returnAllFacts">
                        <default-field title="Response Mode">
                            <drop-down>
                                <option key="N" text="Matched Facts Only"/>
                                <option key="Y" text="Return All Facts (with rule mutations)"/>
                            </drop-down>
                        </default-field>
                    </field>
                    <field name="testButton">
                        <default-field>
                            <submit text="Run Test"/>
                        </default-field>
                    </field>
                    <field name="clearButton">
                        <default-field>
                            <link url="clearTestResult" text="Clear Last Result"/>
                        </default-field>
                    </field>
                </form-single>

                <label text="Last Run Summary: fired=${testFiredRuleCount}, activeRules=${testRuleCount}, results=${testResultRows.size()}"/>
                <label text="Matched Rows Count: ${testMatchedRows.size()}"/>

                <section-iterate name="WarningList" list="testWarnings" entry="warn">
                    <widgets>
                        <label text="Warning: ${warn}" style="text-warning"/>
                    </widgets>
                </section-iterate>
                <label text="Error: ${testError}" condition="testError"/>

                <section-iterate name="ResultList" list="testResultRows" entry="res">
                    <widgets>
                        <container-row>
                            <container-col md="12">
                                <label text="Matched Rules: ${(res._matchedRuleIds ?: [])}" type="strong"/>
                                <label text="Fact: ${res}" type="pre"/>
                            </container-col>
                        </container-row>
                    </widgets>
                </section-iterate>
                <label text="No Test Results Available" condition="testResultRows != null &amp;&amp; testResultRows.size() == 0"/>
            </box-body>
        </container-box>

        <container-box>
            <box-header title="Rules"/>
            <box-body>
                <form-list name="RuleList" list="ruleList" transition="updateRule">
                    <field name="ruleSetId">
                        <default-field>
                            <hidden/>
                        </default-field>
                    </field>
                    <field name="validateOnSave">
                        <default-field>
                            <hidden default-value="true"/>
                        </default-field>
                    </field>
                    <field name="ruleId">
                        <header-field show-order-by="true"/>
                        <default-field>
                            <display/>
                        </default-field>
                    </field>
                    <field name="sequenceNum">
                        <header-field title="Seq" show-order-by="true"/>
                        <default-field>
                            <text-line size="4"/>
                        </default-field>
                    </field>
                    <field name="ruleText">
                        <header-field title="Condition Text"/>
                        <default-field>
                            <text-area rows="2" cols="40"/>
                        </default-field>
                    </field>
                    <field name="ruleLogic">
                        <header-field title="DRL or Condition Override"/>
                        <default-field>
                            <text-area rows="3" cols="55"/>
                        </default-field>
                    </field>
                    <field name="enabled">
                        <header-field title="Active"/>
                        <default-field>
                            <check>
                                <option key="Y"/>
                                <option key="N"/>
                            </check>
                        </default-field>
                    </field>
                    <field name="submitButton">
                        <header-field title="Update"/>
                        <default-field>
                            <submit/>
                        </default-field>
                    </field>
                    <field name="deleteButton">
                        <header-field title="Delete"/>
                        <default-field>
                            <link url="deleteRule" text="X" btn-type="danger" confirmation="Delete rule?" parameter-map="[ruleId:ruleId]"/>
                        </default-field>
                    </field>
                </form-list>

                <container-row>
                    <container-col md="12">
                        <label text="Add New Rule" type="h5"/>
                        <form-single name="NewRule" transition="createRule">
                            <field name="ruleSetId">
                                <default-field>
                                    <hidden/>
                                </default-field>
                            </field>
                            <field name="validateOnSave">
                                <default-field>
                                    <hidden default-value="true"/>
                                </default-field>
                            </field>
                            <field name="ruleId">
                                <default-field>
                                    <text-line size="24" placeholder="Optional rule ID (auto-generated when blank)"/>
                                </default-field>
                            </field>
                            <field name="sequenceNum">
                                <default-field>
                                    <text-line size="6" default-value="10"/>
                                </default-field>
                            </field>
                            <field name="ruleText">
                                <default-field>
                                    <text-line size="70" placeholder="Example: status is 'Pending'"/>
                                </default-field>
                            </field>
                            <field name="ruleLogic">
                                <default-field title="Optional DRL or Condition Override">
                                    <text-area rows="3" cols="70"/>
                                </default-field>
                            </field>
                            <field name="enabled">
                                <default-field>
                                    <hidden default-value="Y"/>
                                </default-field>
                            </field>
                            <field name="addButton">
                                <default-field>
                                    <submit text="Add Rule"/>
                                </default-field>
                            </field>
                        </form-single>
                    </container-col>
                </container-row>
            </box-body>
        </container-box>
    </widgets>
</screen>
