<?xml version="1.0" encoding="UTF-8"?>
<entities xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/entity-definition-3.xsd">

    <entity entity-name="TenantUserPermissionGroupMember" package="darpan.auth" use="configuration" cache="true">
        <description>Assign a reusable Darpan permission group to a user within a specific tenant.</description>
        <field name="tenantUserGroupId" type="id" is-pk="true"/>
        <field name="userId" type="id" is-pk="true"/>
        <field name="permissionUserGroupId" type="id" is-pk="true"/>
        <field name="fromDate" type="date-time" is-pk="true"/>
        <field name="thruDate" type="date-time"/>

        <relationship type="one" title="Tenant" related="moqui.security.UserGroup" short-alias="tenant">
            <key-map field-name="tenantUserGroupId" related-field-name="userGroupId"/>
        </relationship>
        <relationship type="one-nofk" title="User" related="moqui.security.UserAccount" short-alias="user">
            <description>No FK in order to allow externally authenticated users.</description>
            <key-map field-name="userId" related-field-name="userId"/>
        </relationship>
        <relationship type="one" title="Permission" related="moqui.security.UserGroup" short-alias="permission">
            <key-map field-name="permissionUserGroupId" related-field-name="userGroupId"/>
        </relationship>
    </entity>
</entities>
