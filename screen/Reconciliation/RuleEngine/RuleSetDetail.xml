<?xml version="1.0" encoding="UTF-8"?>
<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/xml-screen-3.xsd" default-menu-title="Rule Set Detail">

    <parameter name="ruleSetId" required="true"/>

    <transition name="updateRuleSet">
        <service-call name="update#darpan.rule.RuleSet"/>
        <default-response url="."/>
    </transition>
    <transition name="createRule">
        <service-call name="create#darpan.rule.Rule"/>
        <default-response url="."/>
    </transition>
    <transition name="updateRule">
        <service-call name="update#darpan.rule.Rule"/>
        <default-response url="."/>
    </transition>
    <transition name="deleteRule">
        <service-call name="delete#darpan.rule.Rule"/>
        <default-response url="."/>
    </transition>

    <transition name="compileRuleSet">
        <service-call name="reconciliation.ReconciliationSampleServices.compile#RuleSet"/>
        <default-response url="."/>
    </transition>

    <!-- Test Bench Transition -->
    <!-- We want to run this and show results. Usually we might use a dedicated screen or just render result on same page. -->
    <transition name="testRules">
        <actions>
            <script>
                if (!jsonData) jsonData = '[{"id":1, "status":"Pending"}]'
                if (!ruleSetId) ruleSetId = ruleSetId // Ensure it's in context
            </script>
            <service-call name="reconciliation.ReconciliationSampleServices.execute#RuleSetJson" in-map="[ruleSetId:ruleSetId, jsonData:jsonData]" out-map="context"/>
            <script>ec.web.sendJsonResponse(results)</script>
        </actions>
        <default-response type="none"/>
    </transition>

    <actions>
        <entity-find-one entity-name="darpan.rule.RuleSet" value-field="ruleSet"/>
        <entity-find entity-name="darpan.rule.Rule" list="ruleList">
            <econdition field-name="ruleSetId"/>
            <order-by field-name="sequenceNum"/>
        </entity-find>
    </actions>

    <widgets>
        <container-box>
            <box-header title="Rule Set: ${ruleSet.ruleSetName} (${ruleSetId})"/>
            <box-body>
                <form-single name="RuleSetInfo" map="ruleSet" transition="updateRuleSet">
                    <field name="ruleSetId">
                        <default-field>
                            <display/>
                        </default-field>
                    </field>
                    <field name="ruleSetName">
                        <default-field>
                            <text-line size="40"/>
                        </default-field>
                    </field>
                    <field name="description">
                        <default-field>
                            <text-line size="60"/>
                        </default-field>
                    </field>
                    <field name="version">
                        <default-field>
                            <text-line size="10"/>
                        </default-field>
                    </field>
                    <field name="submitButton">
                        <default-field>
                            <submit text="Update"/>
                        </default-field>
                    </field>
                    <field name="compileButton">
                        <default-field>
                            <link url="compileRuleSet" text="Compile Rules" btn-type="success" confirmation="Compile RuleSet?"/>
                        </default-field>
                    </field>
                </form-single>
            </box-body>
        </container-box>

        <!-- Test Bench Box -->
        <container-box>
            <box-header title="Test Bench"/>
            <box-body>
                <form-single name="TestRulesForm" transition="testRules" map="[ruleSetId:ruleSetId, jsonData:'[{\&quot;id\&quot;:1, \&quot;status\&quot;:\&quot;Pending\&quot;}]']">
                    <field name="ruleSetId">
                        <default-field>
                            <hidden default-value="${ruleSetId}"/>
                        </default-field>
                    </field>
                    <field name="jsonData">
                        <default-field title="JSON Data Packet">
                            <text-area rows="5" cols="80" default-value='[{"id":1, "status":"Pending"}]'/>
                        </default-field>
                    </field>
                    <field name="testButton">
                        <default-field>
                            <submit text="Run Test"/>
                        </default-field>
                    </field>
                </form-single>

                <section-iterate name="ResultList" list="results" entry="res">
                    <widgets>
                        <container-row>
                            <container-col md="12">
                                <label text="Match: Rule ${res.ruleId} - ${res.ruleText}" type="strong" style="text-success"/>
                                <label text="Data: ${res.data}"/>
                            </container-col>
                        </container-row>
                    </widgets>
                </section-iterate>
                <label text="No Matches Found" condition="results != null &amp;&amp; results.size() == 0"/>
            </box-body>
        </container-box>

        <container-box>
            <box-header title="Rules"/>
            <box-body>
                <form-list name="RuleList" list="ruleList" transition="updateRule">
                    <field name="ruleId">
                        <header-field show-order-by="true"/>
                        <default-field>
                            <display/>
                        </default-field>
                    </field>
                    <field name="sequenceNum">
                        <header-field title="Seq" show-order-by="true"/>
                        <default-field>
                            <text-line size="4"/>
                        </default-field>
                    </field>
                    <field name="ruleText">
                        <header-field title="Condition (Text)" show-order-by="true"/>
                        <default-field>
                            <text-area rows="2" cols="40"/>
                        </default-field>
                    </field>
                    <field name="ruleLogic">
                        <header-field title="DRL Override (Optional)"/>
                        <default-field>
                            <text-area rows="2" cols="40"/>
                        </default-field>
                    </field>
                    <field name="enabled">
                        <header-field title="Active"/>
                        <default-field>
                            <check>
                                <option key="Y"/>
                                <option key="N"/>
                            </check>
                        </default-field>
                    </field>
                    <field name="submitButton">
                        <header-field title="Update"/>
                        <default-field>
                            <submit/>
                        </default-field>
                    </field>
                    <field name="deleteButton">
                        <header-field title="Delete"/>
                        <default-field>
                            <link url="deleteRule" text="X" btn-type="danger" confirmation="Delete rule?"/>
                        </default-field>
                    </field>
                </form-list>

                <container-row>
                    <container-col md="12">
                        <label text="Add New Rule" type="h5"/>
                        <form-single name="NewRule" transition="createRule">
                            <field name="ruleSetId">
                                <default-field>
                                    <hidden/>
                                </default-field>
                            </field>
                            <field name="ruleId">
                                <default-field>
                                    <text-line size="20" placeholder="Rule ID (Unique)"/>
                                </default-field>
                            </field>
                            <field name="sequenceNum">
                                <default-field>
                                    <text-line size="5" default-value="10"/>
                                </default-field>
                            </field>
                            <field name="ruleText">
                                <default-field>
                                    <text-line size="60" placeholder="e.g. status is 'Pending'"/>
                                </default-field>
                            </field>
                            <field name="enabled">
                                <default-field>
                                    <hidden default-value="Y"/>
                                </default-field>
                            </field>
                            <field name="addButton">
                                <default-field>
                                    <submit text="Add Rule"/>
                                </default-field>
                            </field>
                        </form-single>
                    </container-col>
                </container-row>
            </box-body>
        </container-box>
    </widgets>
</screen>
