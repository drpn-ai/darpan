<?xml version="1.0" encoding="UTF-8"?>
<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/xml-screen-3.xsd" default-menu-title="Read DB Settings" require-authentication="true">

    <parameter name="editHcReadDbConfigId"/>

    <transition name="saveHcReadDbConfig">
        <actions>
            <set field="hcReadDbConfigId" from="hcReadDbConfigId?.trim()"/>
            <set field="hcDisplayName" from="hcDisplayName?.trim()"/>
            <set field="hcHost" from="hcHost?.trim()"/>
            <set field="hcDatabaseName" from="hcDatabaseName?.trim()"/>
            <set field="hcUsername" from="hcUsername?.trim()"/>
            <set field="hcDbDriver" from="hcDbDriver?.trim()"/>
            <set field="hcDefaultTableName" from="hcDefaultTableName?.trim()"/>
            <set field="hcItemIdColumn" from="hcItemIdColumn?.trim()"/>
            <set field="hcLocationIdColumn" from="hcLocationIdColumn?.trim()"/>
            <set field="hcTransactionDateColumn" from="hcTransactionDateColumn?.trim()"/>
            <set field="hcConnectionPropertiesJson" from="hcConnectionPropertiesJson?.trim()"/>
            <set field="hcAdditionalParameters" from="hcAdditionalParameters?.trim()"/>
            <set field="hcIsActive" from="hcIsActive?.trim()?.toUpperCase()"/>

            <if condition="!hcHost">
                <message type="error" text="Host is required."/>
                <return error="true"/>
            </if>
            <if condition="!hcDatabaseName">
                <message type="error" text="Database Name is required."/>
                <return error="true"/>
            </if>
            <if condition="!hcUsername">
                <message type="error" text="Username is required for DB access."/>
                <return error="true"/>
            </if>
            <if condition="hcConnectionPropertiesJson">
                <script><![CDATA[
                    try {
                        def parsedProps = new groovy.json.JsonSlurper().parseText(hcConnectionPropertiesJson)
                        if (!(parsedProps instanceof Map)) {
                            ec.message.addError("Connection Properties JSON must be a JSON object.")
                        }
                    } catch (Exception e) {
                        ec.message.addError("Connection Properties JSON is invalid: ${e.message}")
                    }
                ]]>                </script>
            </if>

            <script><![CDATA[
                def normalizeId = { String rawValue ->
                    rawValue?.toLowerCase()
                            ?.replaceAll(/[^a-z0-9_-]+/, "_")
                            ?.replaceAll(/^_+|_+$/, "")
                }

                Integer resolvedPort = 3306
                if (hcPort) {
                    try {
                        resolvedPort = hcPort as Integer
                    } catch (Exception e) {
                        ec.message.addError("Port must be a valid integer.")
                    }
                }
                if (resolvedPort <= 0) ec.message.addError("Port must be greater than 0.")

                String cleanAdditional = hcAdditionalParameters?.trim()
                if (cleanAdditional?.startsWith("?")) cleanAdditional = cleanAdditional.substring(1)

                String resolvedConfigId = hcReadDbConfigId
                if (resolvedConfigId) {
                    String normalized = normalizeId(resolvedConfigId)
                    if (!normalized) {
                        ec.message.addError("Config ID must contain letters or numbers.")
                    } else {
                        if (normalized != resolvedConfigId) {
                            ec.message.addMessage("Config ID normalized to ${normalized}.")
                        }
                        resolvedConfigId = normalized
                    }
                } else {
                    String seed = hcDisplayName ?: "${hcHost ?: 'hc'}_${hcDatabaseName ?: 'db'}"
                    String baseId = normalizeId(seed) ?: "hc_db"
                    if (baseId.length() > 40) baseId = baseId.substring(0, 40)

                    String candidateId = baseId
                    int suffix = 1
                    while (ec.entity.find("darpan.reconciliation.HcReadDbConfig")
                            .condition("hcReadDbConfigId", candidateId)
                            .useCache(false)
                            .one()) {
                        suffix++
                        String suffixPart = "_${suffix}"
                        int maxBaseLength = Math.max(1, 40 - suffixPart.length())
                        String trimmedBase = baseId.length() > maxBaseLength ? baseId.substring(0, maxBaseLength) : baseId
                        candidateId = trimmedBase + suffixPart
                    }
                    resolvedConfigId = candidateId
                    ec.message.addMessage("Config ID auto-generated as ${resolvedConfigId}.")
                }
                if (resolvedConfigId?.length() > 40) resolvedConfigId = resolvedConfigId.substring(0, 40)

                String generatedJdbcUrl = "jdbc:mysql://${hcHost}:${resolvedPort}/${hcDatabaseName}"
                if (cleanAdditional) generatedJdbcUrl += "?${cleanAdditional}"

                def existingHc = ec.entity.find("darpan.reconciliation.HcReadDbConfig")
                        .condition("hcReadDbConfigId", resolvedConfigId)
                        .useCache(false)
                        .one()
                Map hcMap = [
                        hcReadDbConfigId     : resolvedConfigId,
                        description          : hcDisplayName,
                        displayName          : hcDisplayName,
                        host                 : hcHost,
                        port                 : resolvedPort,
                        databaseName         : hcDatabaseName,
                        additionalParameters : cleanAdditional,
                        jdbcUrl              : generatedJdbcUrl,
                        username             : hcUsername,
                        dbDriver             : hcDbDriver ?: 'com.mysql.cj.jdbc.Driver',
                        defaultTableName     : hcDefaultTableName ?: 'inventory_item_detail',
                        itemIdColumn         : hcItemIdColumn ?: 'product_id',
                        locationIdColumn     : hcLocationIdColumn ?: 'facility_id',
                        transactionDateColumn: hcTransactionDateColumn ?: 'effective_date',
                        connectionPropertiesJson: hcConnectionPropertiesJson,
                        isActive             : hcIsActive ?: 'Y'
                ]
                if (hcPassword) hcMap.password = hcPassword
                if (!hcPassword && existingHc?.password) hcMap.password = existingHc.password
                context.hcReadDbConfigId = resolvedConfigId
                context.hcMap = hcMap
                context.generatedJdbcUrl = generatedJdbcUrl
            ]]>            </script>

            <if condition="ec.message.hasError()">
                <return error="true"/>
            </if>

            <script><![CDATA[
                String entityName = "darpan.reconciliation.HcReadDbConfig"
                String groupName = ec.entity.getEntityGroupName(entityName)
                def datasourceFactory = groupName ? ec.entity.getDatasourceFactory(groupName) : null
                if (!datasourceFactory) {
                    ec.message.addError("Could not resolve datasource for ${entityName}.")
                    return
                }

                if (!datasourceFactory.checkTableExists(entityName)) {
                    datasourceFactory.checkAndAddTable(entityName)
                }
                if (!datasourceFactory.checkTableExists(entityName)) {
                    ec.message.addError("Database table READ_DB_CONFIG is missing and could not be created automatically.")
                }
            ]]>            </script>

            <if condition="ec.message.hasError()">
                <return error="true"/>
            </if>

            <service-call name="store#darpan.reconciliation.HcReadDbConfig" in-map="hcMap"/>
            <if condition="ec.message.hasError()">
                <return error="true"/>
            </if>
            <message>Saved Read DB config ${hcReadDbConfigId} (${generatedJdbcUrl}).</message>
        </actions>
        <default-response url=".">
            <parameter name="editHcReadDbConfigId" from="hcReadDbConfigId"/>
        </default-response>
    </transition>

    <pre-actions>
        <if condition="!darpan.facade.common.TenantAccessSupport.isSuperAdmin(ec)">
            <return error="true" message="Reconciliation administration screens are restricted to super-admin users."/>
        </if>
        <script><![CDATA[
            def hcConfigs = []
            ec.entity.find("darpan.reconciliation.HcReadDbConfig")
                    .useCache(false)
                    .orderBy(["displayName", "hcReadDbConfigId"])
                    .list()
                    ?.each { cfg ->
                        String safeJdbcUrl = cfg.jdbcUrl?.toString()?.replaceAll("(?i)(password=)[^&;]+", "\$1***")
                        hcConfigs.add([
                                hcReadDbConfigId     : cfg.hcReadDbConfigId,
                                displayName          : cfg.displayName ?: cfg.description,
                                host                 : cfg.host,
                                port                 : cfg.port,
                                databaseName         : cfg.databaseName,
                                additionalParameters : cfg.additionalParameters,
                                jdbcUrl              : safeJdbcUrl,
                                username             : cfg.username,
                                dbDriver             : cfg.dbDriver,
                                defaultTableName     : cfg.defaultTableName,
                                itemIdColumn         : cfg.itemIdColumn,
                                locationIdColumn     : cfg.locationIdColumn,
                                transactionDateColumn: cfg.transactionDateColumn,
                                isActive             : cfg.isActive,
                                hasPassword          : !!cfg.password
                        ])
                    }
            context.hcReadDbConfigs = hcConfigs
        ]]>        </script>

        <if condition="editHcReadDbConfigId">
            <script><![CDATA[
                String cfgId = editHcReadDbConfigId?.toString()?.trim()
                if (cfgId) {
                    def cfg = ec.entity.find("darpan.reconciliation.HcReadDbConfig")
                            .condition("hcReadDbConfigId", cfgId)
                            .useCache(false)
                            .one()
                    if (cfg) {
                        String resolvedHost = cfg.host?.toString()
                        Integer resolvedPort = cfg.port ?: 3306
                        String resolvedDatabase = cfg.databaseName?.toString()
                        String resolvedAdditional = cfg.additionalParameters?.toString()

                        if ((!resolvedHost || !resolvedDatabase) && cfg.jdbcUrl) {
                            def matcher = (cfg.jdbcUrl.toString() =~ /^jdbc:mysql:\/\/([^:\/?]+)(?::(\d+))?\/([^?]+)(?:\?(.*))?$/)
                            if (matcher.matches()) {
                                if (!resolvedHost) resolvedHost = matcher[0][1]
                                if (!cfg.port && matcher[0][2]) resolvedPort = matcher[0][2] as Integer
                                if (!resolvedDatabase) resolvedDatabase = matcher[0][3]
                                if (!resolvedAdditional && matcher[0][4]) resolvedAdditional = matcher[0][4]
                            }
                        }

                        context.hcReadDbConfigId = cfg.hcReadDbConfigId
                        context.hcDisplayName = cfg.displayName ?: cfg.description
                        context.hcHost = resolvedHost
                        context.hcPort = resolvedPort ?: 3306
                        context.hcDatabaseName = resolvedDatabase
                        context.hcAdditionalParameters = resolvedAdditional
                        context.hcUsername = cfg.username
                        context.hcDbDriver = cfg.dbDriver ?: "com.mysql.cj.jdbc.Driver"
                        context.hcDefaultTableName = cfg.defaultTableName ?: "inventory_item_detail"
                        context.hcItemIdColumn = cfg.itemIdColumn ?: "product_id"
                        context.hcLocationIdColumn = cfg.locationIdColumn ?: "facility_id"
                        context.hcTransactionDateColumn = cfg.transactionDateColumn ?: "effective_date"
                        context.hcConnectionPropertiesJson = cfg.connectionPropertiesJson
                        context.hcIsActive = cfg.isActive ?: "Y"
                        context.hcHasPassword = !!cfg.password
                    }
                }
            ]]>            </script>
        </if>
    </pre-actions>

    <widgets>
        <container style="container">
            <container style="page-header">
                <label text="Read-Only DB Settings" type="h2"/>
                <label text="Save database connections as Host/Port/Database + credentials. JDBC URL is generated internally." type="p" style="text-muted"/>
            </container>

            <section name="HcReadDbConfigSection">
                <widgets>
                    <label text="Read-Only DB Settings" type="h4"/>
                    <label text="${hcReadDbConfigId ? 'Edit Read DB Config' : 'Add Read DB Config'}" type="p" style="text-muted"/>
                    <label text="Leave Config ID blank to auto-generate from Display Name/Host/Database." type="p" style="text-muted"/>
                    <label text="Stored Password: ${hcHasPassword ? 'Yes' : 'No'}" condition="hcReadDbConfigId" type="p" style="text-info"/>
                    <form-single name="HcReadDbConfigForm" transition="saveHcReadDbConfig">
                        <field name="hcReadDbConfigId">
                            <default-field title="Config ID (optional)">
                                <text-line size="30"/>
                            </default-field>
                        </field>
                        <field name="hcDisplayName">
                            <default-field title="Display Name">
                                <text-line size="60"/>
                            </default-field>
                        </field>
                        <field name="hcHost">
                            <default-field title="Host">
                                <text-line size="60"/>
                            </default-field>
                        </field>
                        <field name="hcPort">
                            <default-field title="Port">
                                <text-line size="8" default-value="3306"/>
                            </default-field>
                        </field>
                        <field name="hcDatabaseName">
                            <default-field title="Database Name">
                                <text-line size="40"/>
                            </default-field>
                        </field>
                        <field name="hcUsername">
                            <default-field title="Username">
                                <text-line size="40"/>
                            </default-field>
                        </field>
                        <field name="hcPassword">
                            <default-field title="Password (leave blank to keep existing)">
                                <password size="40"/>
                            </default-field>
                        </field>
                        <field name="hcAdditionalParameters">
                            <default-field title="Additional Parameters">
                                <text-line size="100"/>
                            </default-field>
                        </field>
                        <field name="hcDbDriver">
                            <default-field title="DB Driver">
                                <text-line size="50" default-value="com.mysql.cj.jdbc.Driver"/>
                            </default-field>
                        </field>
                        <field name="hcDefaultTableName">
                            <default-field title="Default Table">
                                <text-line size="40" default-value="inventory_item_detail"/>
                            </default-field>
                        </field>
                        <field name="hcItemIdColumn">
                            <default-field title="Item ID Column">
                                <text-line size="30" default-value="product_id"/>
                            </default-field>
                        </field>
                        <field name="hcLocationIdColumn">
                            <default-field title="Location ID Column">
                                <text-line size="30" default-value="facility_id"/>
                            </default-field>
                        </field>
                        <field name="hcTransactionDateColumn">
                            <default-field title="Date Column">
                                <text-line size="30" default-value="effective_date"/>
                            </default-field>
                        </field>
                        <field name="hcConnectionPropertiesJson">
                            <default-field title="Connection Properties JSON">
                                <text-area cols="80" rows="3"/>
                            </default-field>
                        </field>
                        <field name="hcIsActive">
                            <default-field title="Active?">
                                <check checked-value="Y" unchecked-value="N"/>
                            </default-field>
                        </field>
                        <field name="saveHcConfigButton">
                            <default-field title="">
                                <submit text="Save Read DB Config" btn-type="primary"/>
                            </default-field>
                        </field>

                        <field-layout>
                            <field-row>
                                <field-ref name="hcReadDbConfigId"/>
                                <field-ref name="hcDisplayName"/>
                            </field-row>
                            <field-row>
                                <field-ref name="hcHost"/>
                                <field-ref name="hcPort"/>
                                <field-ref name="hcDatabaseName"/>
                            </field-row>
                            <field-row>
                                <field-ref name="hcUsername"/>
                                <field-ref name="hcPassword"/>
                            </field-row>
                            <field-row>
                                <field-ref name="hcAdditionalParameters"/>
                            </field-row>
                            <field-row>
                                <field-ref name="hcDbDriver"/>
                                <field-ref name="hcDefaultTableName"/>
                            </field-row>
                            <field-row>
                                <field-ref name="hcItemIdColumn"/>
                                <field-ref name="hcLocationIdColumn"/>
                                <field-ref name="hcTransactionDateColumn"/>
                            </field-row>
                            <field-row-big>
                                <field-ref name="hcConnectionPropertiesJson"/>
                            </field-row-big>
                            <field-row>
                                <field-ref name="hcIsActive"/>
                            </field-row>
                            <field-row-big>
                                <field-ref name="saveHcConfigButton"/>
                            </field-row-big>
                        </field-layout>
                    </form-single>
                </widgets>
            </section>

            <container type="hr"/>

            <section name="HcReadDbConfigListSection">
                <widgets>
                    <label text="Existing Read DB Configs" type="h4"/>
                    <section name="NoHcConfigs" condition="!hcReadDbConfigs">
                        <widgets>
                            <label text="No Read DB configs found." type="p" style="text-muted"/>
                        </widgets>
                    </section>
                    <section name="HcConfigsTable" condition="hcReadDbConfigs">
                        <widgets>
                            <form-list name="HcReadDbConfigsList" list="hcReadDbConfigs" skip-form="true" paginate="true" paginate-always-show="true" style="table table-striped table-condensed">
                                <field name="hcReadDbConfigId">
                                    <header-field title="Config ID"/>
                                    <default-field><display/></default-field>
                                </field>
                                <field name="displayName">
                                    <header-field title="Display Name"/>
                                    <default-field><display/></default-field>
                                </field>
                                <field name="host">
                                    <header-field title="Host"/>
                                    <default-field><display/></default-field>
                                </field>
                                <field name="port">
                                    <header-field title="Port"/>
                                    <default-field><display/></default-field>
                                </field>
                                <field name="databaseName">
                                    <header-field title="Database"/>
                                    <default-field><display/></default-field>
                                </field>
                                <field name="username">
                                    <header-field title="Username"/>
                                    <default-field><display/></default-field>
                                </field>
                                <field name="isActive">
                                    <header-field title="Active"/>
                                    <default-field><display/></default-field>
                                </field>
                                <field name="hasPassword">
                                    <header-field title="Password?"/>
                                    <default-field>
                                        <label text="${hasPassword ? 'Yes' : 'No'}" type="span"/>
                                    </default-field>
                                </field>
                                <field name="actions">
                                    <header-field title=""/>
                                    <default-field>
                                        <link url="." text="Edit" link-type="anchor-button" btn-type="info" style="btn-xs">
                                            <parameter name="editHcReadDbConfigId" from="hcReadDbConfigId"/>
                                        </link>
                                    </default-field>
                                </field>
                            </form-list>
                        </widgets>
                    </section>
                </widgets>
            </section>
        </container>
    </widgets>
</screen>
