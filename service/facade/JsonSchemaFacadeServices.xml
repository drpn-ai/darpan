<?xml version="1.0" encoding="UTF-8"?>
<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/service-definition-3.xsd">

    <service verb="list" noun="JsonSchemas" allow-remote="true" authenticate="true">
        <description>List active JSON schemas with pagination for darpan-ui browse page.</description>
        <in-parameters>
            <parameter name="query"/>
            <parameter name="pageIndex" type="Integer" default-value="0"/>
            <parameter name="pageSize" type="Integer" default-value="20"/>
        </in-parameters>
        <out-parameters>
            <parameter name="ok" type="Boolean"/>
            <parameter name="messages"><parameter name="message"/></parameter>
            <parameter name="errors"><parameter name="error"/></parameter>
            <parameter name="pagination">
                <parameter name="pageIndex" type="Integer"/>
                <parameter name="pageSize" type="Integer"/>
                <parameter name="totalCount" type="Integer"/>
                <parameter name="pageCount" type="Integer"/>
            </parameter>
            <parameter name="schemas">
                <parameter name="jsonSchemaId"/>
                <parameter name="schemaName"/>
                <parameter name="description"/>
                <parameter name="systemEnumId"/>
                <parameter name="systemLabel"/>
                <parameter name="companyUserGroupId"/>
                <parameter name="createdByUserId"/>
                <parameter name="statusId"/>
                <parameter name="createdDate" type="Timestamp"/>
                <parameter name="lastUpdatedStamp" type="Timestamp"/>
            </parameter>
        </out-parameters>
        <actions>
            <set field="pageIndexSafe" from="Math.max(0, darpan.facade.common.FacadeSupport.normalizeInt(pageIndex, 0))"/>
            <set field="pageSizeSafe" from="Math.max(1, Math.min(200, darpan.facade.common.FacadeSupport.normalizeInt(pageSize, 20)))"/>
            <set field="searchLower" from="darpan.facade.common.FacadeSupport.normalize(query)?.toLowerCase()"/>
            <set field="schemas" from="[]"/>
            <set field="pagination" from="[pageIndex: pageIndexSafe, pageSize: pageSizeSafe, totalCount: 0, pageCount: 1]"/>
            <set field="ignoreTableEnsure" from="jsonschema.common.JsonSchemaUtil.ensureJsonSchemaTable(ec)"/>
            <set field="schemaFinder" from="ec.entity.find('darpan.reconciliation.JsonSchema').condition('statusId', 'Active').orderBy('-lastUpdatedStamp').useCache(false)"/>
            <set field="ignoreCompanyFilter" from="darpan.facade.common.PilotAccessSupport.applyCompanyFilter(schemaFinder, ec)"/>
            <set field="rows" from="(schemaFinder.list() ?: []).collect { item -> [jsonSchemaId: item.jsonSchemaId, schemaName: item.schemaName, description: item.description, systemEnumId: darpan.facade.common.FacadeSupport.normalize(item.systemEnumId), systemLabel: jsonschema.common.JsonSchemaUtil.resolveSystemLabel(ec, item.systemEnumId, null, true), companyUserGroupId: item.companyUserGroupId, createdByUserId: item.createdByUserId, statusId: item.statusId, createdDate: item.createdDate, lastUpdatedStamp: item.lastUpdatedStamp] }"/>
            <set field="filteredRows" from="searchLower ? rows.findAll { row -> [row.schemaName, row.description].any { it?.toString()?.toLowerCase()?.contains(searchLower) } } : rows"/>
            <set field="totalCount" from="filteredRows.size()"/>
            <set field="fromIndex" from="Math.min(pageIndexSafe * pageSizeSafe, totalCount)"/>
            <set field="toIndex" from="Math.min(fromIndex + pageSizeSafe, totalCount)"/>
            <set field="schemas" from="filteredRows.subList(fromIndex, toIndex)"/>
            <set field="pagination" from="[pageIndex: pageIndexSafe, pageSize: pageSizeSafe, totalCount: totalCount, pageCount: Math.max(1, Math.ceil(totalCount / (double) pageSizeSafe) as int)]"/>
            <set field="ok" from="!ec.message.hasError()"/>
            <set field="messages" from="darpan.facade.common.FacadeSupport.getMessages(ec)"/>
            <set field="errors" from="darpan.facade.common.FacadeSupport.getErrors(ec)"/>
        </actions>
    </service>

    <service verb="get" noun="JsonSchema" allow-remote="true" authenticate="true">
        <description>Get a single JSON schema including schemaText.</description>
        <in-parameters>
            <parameter name="jsonSchemaId"/>
            <parameter name="schemaName"/>
        </in-parameters>
        <out-parameters>
            <parameter name="ok" type="Boolean"/>
            <parameter name="messages"><parameter name="message"/></parameter>
            <parameter name="errors"><parameter name="error"/></parameter>
            <parameter name="schemaData">
                <parameter name="jsonSchemaId"/>
                <parameter name="schemaName"/>
                <parameter name="description"/>
                <parameter name="systemEnumId"/>
                <parameter name="systemLabel"/>
                <parameter name="ownerUserId"/>
                <parameter name="companyUserGroupId"/>
                <parameter name="createdByUserId"/>
                <parameter name="schemaText" allow-html="true"/>
                <parameter name="statusId"/>
                <parameter name="createdDate" type="Timestamp"/>
                <parameter name="lastUpdatedStamp" type="Timestamp"/>
            </parameter>
        </out-parameters>
        <actions>
            <set field="jsonSchemaIdValue" from="darpan.facade.common.FacadeSupport.normalize(jsonSchemaId)"/>
            <set field="schemaNameValue" from="darpan.facade.common.FacadeSupport.normalize(schemaName)"/>
            <set field="ignoreTableEnsure" from="jsonschema.common.JsonSchemaUtil.ensureJsonSchemaTable(ec)"/>
            <if condition="!jsonSchemaIdValue &amp;&amp; !schemaNameValue">
                <message error="true">jsonSchemaId or schemaName is required</message>
            </if>
            <if condition="!ec.message.hasError() &amp;&amp; jsonSchemaIdValue">
                <set field="schema" from="ec.entity.find('darpan.reconciliation.JsonSchema').condition('jsonSchemaId', jsonSchemaIdValue).useCache(false).one()"/>
            </if>
            <if condition="!ec.message.hasError() &amp;&amp; !schema &amp;&amp; schemaNameValue">
                <set field="schema" from="ec.entity.find('darpan.reconciliation.JsonSchema').condition('schemaName', schemaNameValue).useCache(false).one()"/>
            </if>
            <if condition="!ec.message.hasError()">
                <set field="ignoreAccessCheck" from="darpan.facade.common.PilotAccessSupport.requireCompanyRecordAccess(ec, schema, 'Schema not found', 'Schema is not available in your active company.')"/>
            </if>
            <if condition="!ec.message.hasError()">
                <set field="systemEnumIdValue" from="darpan.facade.common.FacadeSupport.normalize(schema.systemEnumId)"/>
                <set field="schemaData" from="[jsonSchemaId: schema.jsonSchemaId, schemaName: schema.schemaName, description: schema.description, systemEnumId: systemEnumIdValue, systemLabel: jsonschema.common.JsonSchemaUtil.resolveSystemLabel(ec, systemEnumIdValue, null, true), ownerUserId: schema.ownerUserId, companyUserGroupId: schema.companyUserGroupId, createdByUserId: schema.createdByUserId, schemaText: schema.schemaText, statusId: schema.statusId, createdDate: schema.createdDate, lastUpdatedStamp: schema.lastUpdatedStamp]"/>
            </if>
            <set field="ok" from="!ec.message.hasError()"/>
            <set field="messages" from="darpan.facade.common.FacadeSupport.getMessages(ec)"/>
            <set field="errors" from="darpan.facade.common.FacadeSupport.getErrors(ec)"/>
        </actions>
    </service>

    <service verb="save" noun="JsonSchemaText" allow-remote="true" authenticate="true">
        <description>Save schema text directly from darpan-ui (no backend screen transition dependency).</description>
        <in-parameters>
            <parameter name="jsonSchemaId"/>
            <parameter name="schemaName"/>
            <parameter name="description"/>
            <parameter name="systemEnumId"/>
            <parameter name="schemaText" required="true" allow-html="true"/>
            <parameter name="overwrite" type="Boolean" default-value="false"/>
        </in-parameters>
        <out-parameters>
            <parameter name="ok" type="Boolean"/>
            <parameter name="messages"><parameter name="message"/></parameter>
            <parameter name="errors"><parameter name="error"/></parameter>
            <parameter name="savedSchema">
                <parameter name="jsonSchemaId"/>
                <parameter name="schemaName"/>
                <parameter name="description"/>
                <parameter name="systemEnumId"/>
                <parameter name="systemLabel"/>
                <parameter name="ownerUserId"/>
                <parameter name="companyUserGroupId"/>
                <parameter name="createdByUserId"/>
                <parameter name="statusId"/>
                <parameter name="lastUpdatedStamp" type="Timestamp"/>
            </parameter>
        </out-parameters>
        <actions>
            <set field="schemaNameValue" from="darpan.facade.common.FacadeSupport.normalize(schemaName)"/>
            <set field="schemaTextValue" from="darpan.facade.common.FacadeSupport.normalize(schemaText)"/>
            <set field="descriptionValue" from="darpan.facade.common.FacadeSupport.normalize(description)"/>
            <set field="schemaIdValue" from="darpan.facade.common.FacadeSupport.normalize(jsonSchemaId)"/>
            <set field="requestedSystemEnumIdValue" from="darpan.facade.common.FacadeSupport.normalize(systemEnumId)"/>
            <set field="overwriteMode" from="darpan.facade.common.FacadeSupport.normalizeBool(overwrite, false)"/>
            <set field="hasSystemEnumIdInput" from="context.containsKey('systemEnumId')"/>
            <set field="systemEnumIdValue" from="hasSystemEnumIdInput ? requestedSystemEnumIdValue : null"/>
            <set field="jsonValidationError" from="jsonschema.common.JsonSchemaUtil.validateJsonText(schemaTextValue, 'schemaText')"/>
            <set field="ignoreTableEnsure" from="jsonschema.common.JsonSchemaUtil.ensureJsonSchemaTable(ec)"/>
            <if condition="!schemaIdValue &amp;&amp; !schemaNameValue">
                <message error="true">schemaName is required when jsonSchemaId is not provided</message>
            </if>
            <if condition="jsonValidationError">
                <message error="true">${jsonValidationError}</message>
            </if>
            <if condition="hasSystemEnumIdInput &amp;&amp; requestedSystemEnumIdValue &amp;&amp; !jsonschema.common.JsonSchemaUtil.findSystemEnum(ec, requestedSystemEnumIdValue, false)">
                <message error="true">systemEnumId '${requestedSystemEnumIdValue}' is not a valid reconciliation system.</message>
            </if>
            <if condition="!ec.message.hasError() &amp;&amp; schemaIdValue">
                <set field="existingSchema" from="ec.entity.find('darpan.reconciliation.JsonSchema').condition('jsonSchemaId', schemaIdValue).useCache(false).one()"/>
                <set field="ignoreAccessCheck" from="darpan.facade.common.PilotAccessSupport.requireCompanyRecordAccess(ec, existingSchema, &quot;Schema not found for ID '${schemaIdValue}'&quot;, 'Schema is not available in your active company.')"/>
            </if>
            <if condition="!ec.message.hasError()">
                <set field="resolvedName" from="existingSchema ? (schemaNameValue ?: existingSchema.schemaName) : jsonschema.common.JsonSchemaUtil.generateUniqueSchemaName(ec, schemaNameValue, overwriteMode)"/>
                <if condition="existingSchema &amp;&amp; resolvedName != existingSchema.schemaName">
                    <set field="duplicateSchema" from="ec.entity.find('darpan.reconciliation.JsonSchema').condition('schemaName', resolvedName).useCache(false).one()"/>
                    <if condition="duplicateSchema &amp;&amp; duplicateSchema.jsonSchemaId != existingSchema.jsonSchemaId">
                        <message error="true">Schema name '${resolvedName}' already exists</message>
                    </if>
                </if>
            </if>
            <if condition="!ec.message.hasError() &amp;&amp; existingSchema">
                <set field="ignoreSchemaName" from="existingSchema.set('schemaName', resolvedName)"/>
                <set field="ignoreSchemaText" from="existingSchema.set('schemaText', schemaTextValue)"/>
                <if condition="description != null">
                    <set field="ignoreDescription" from="existingSchema.set('description', descriptionValue)"/>
                </if>
                <if condition="hasSystemEnumIdInput">
                    <set field="ignoreSystemEnum" from="existingSchema.set('systemEnumId', systemEnumIdValue)"/>
                </if>
                <if condition="!existingSchema.statusId">
                    <set field="ignoreStatusId" from="existingSchema.set('statusId', 'Active')"/>
                </if>
                <set field="ignoreLastUpdated" from="existingSchema.set('lastUpdatedStamp', ec.user.nowTimestamp)"/>
                <set field="ignoreSchemaUpdate" from="existingSchema.update()"/>
                <set field="savedSchemaEntity" from="existingSchema"/>
            </if>
            <if condition="!ec.message.hasError() &amp;&amp; !existingSchema">
                <set field="newSchemaMap" from="[schemaName: resolvedName, schemaText: schemaTextValue, description: descriptionValue, systemEnumId: systemEnumIdValue, statusId: 'Active', createdDate: ec.user.nowTimestamp, lastUpdatedStamp: ec.user.nowTimestamp]"/>
                <set field="ignoreCompanyAssignment" from="darpan.facade.common.PilotAccessSupport.assignCompanyOwnershipOnCreate(newSchemaMap, ec)"/>
                <if condition="!ec.message.hasError()">
                    <service-call name="create#darpan.reconciliation.JsonSchema" in-map="newSchemaMap" out-map="createSchemaResult"/>
                    <set field="savedSchemaEntity" from="ec.entity.find('darpan.reconciliation.JsonSchema').condition('jsonSchemaId', createSchemaResult.jsonSchemaId).useCache(false).one()"/>
                </if>
            </if>
            <if condition="!ec.message.hasError()">
                <set field="savedSystemEnumId" from="darpan.facade.common.FacadeSupport.normalize(savedSchemaEntity?.systemEnumId)"/>
                <set field="savedSchema" from="[jsonSchemaId: savedSchemaEntity?.jsonSchemaId, schemaName: savedSchemaEntity?.schemaName, description: savedSchemaEntity?.description, systemEnumId: savedSystemEnumId, systemLabel: jsonschema.common.JsonSchemaUtil.resolveSystemLabel(ec, savedSystemEnumId, null, true), ownerUserId: savedSchemaEntity?.ownerUserId, companyUserGroupId: savedSchemaEntity?.companyUserGroupId, createdByUserId: savedSchemaEntity?.createdByUserId, statusId: savedSchemaEntity?.statusId, lastUpdatedStamp: savedSchemaEntity?.lastUpdatedStamp]"/>
                <message>Saved schema ${savedSchema.schemaName}.</message>
            </if>
            <set field="ok" from="!ec.message.hasError()"/>
            <set field="messages" from="darpan.facade.common.FacadeSupport.getMessages(ec)"/>
            <set field="errors" from="darpan.facade.common.FacadeSupport.getErrors(ec)"/>
        </actions>
    </service>

    <service verb="infer" noun="JsonSchemaFromText" type="script" allow-remote="true" authenticate="true"
            location="component://darpan/src/main/groovy/darpan/facade/jsonschema/inferJsonSchemaFromText.groovy">
        <description>Infer schema from JSON text and return flattened editor field rows.</description>
        <in-parameters>
            <parameter name="jsonText" required="true" allow-html="true"/>
        </in-parameters>
        <out-parameters>
            <parameter name="ok" type="Boolean"/>
            <parameter name="messages"><parameter name="message"/></parameter>
            <parameter name="errors"><parameter name="error"/></parameter>
            <parameter name="jsonSchemaString" allow-html="true"/>
            <parameter name="fieldList" type="List"/>
        </out-parameters>
    </service>

    <service verb="validate" noun="JsonTextAgainstSchema" type="script" allow-remote="true" authenticate="true"
            location="component://darpan/src/main/groovy/darpan/facade/jsonschema/validateJsonText.groovy">
        <description>Validate JSON text against a saved schema.</description>
        <in-parameters>
            <parameter name="jsonText" required="true" allow-html="true"/>
            <parameter name="jsonSchemaId"/>
            <parameter name="schemaName"/>
        </in-parameters>
        <out-parameters>
            <parameter name="ok" type="Boolean"/>
            <parameter name="messages"><parameter name="message"/></parameter>
            <parameter name="errors"><parameter name="error"/></parameter>
            <parameter name="valid" type="Boolean"/>
            <parameter name="errorCount" type="Integer"/>
            <parameter name="errorMessages"><parameter name="errorMessage"/></parameter>
        </out-parameters>
    </service>

    <service verb="flatten" noun="JsonSchema" allow-remote="true" authenticate="true">
        <description>Flatten a saved schema to editor field rows.</description>
        <in-parameters>
            <parameter name="jsonSchemaId"/>
            <parameter name="schemaName"/>
        </in-parameters>
        <out-parameters>
            <parameter name="ok" type="Boolean"/>
            <parameter name="messages"><parameter name="message"/></parameter>
            <parameter name="errors"><parameter name="error"/></parameter>
            <parameter name="jsonSchemaString" allow-html="true"/>
            <parameter name="fieldList" type="List"/>
        </out-parameters>
        <actions>
            <set field="jsonSchemaIdValue" from="darpan.facade.common.FacadeSupport.normalize(jsonSchemaId)"/>
            <set field="schemaNameValue" from="darpan.facade.common.FacadeSupport.normalize(schemaName)"/>
            <if condition="!jsonSchemaIdValue &amp;&amp; !schemaNameValue">
                <message error="true">jsonSchemaId or schemaName is required</message>
            </if>
            <if condition="!ec.message.hasError() &amp;&amp; jsonSchemaIdValue">
                <set field="schema" from="ec.entity.find('darpan.reconciliation.JsonSchema').condition('jsonSchemaId', jsonSchemaIdValue).useCache(false).one()"/>
            </if>
            <if condition="!ec.message.hasError() &amp;&amp; !schema &amp;&amp; schemaNameValue">
                <set field="schema" from="ec.entity.find('darpan.reconciliation.JsonSchema').condition('schemaName', schemaNameValue).useCache(false).one()"/>
            </if>
            <if condition="!ec.message.hasError()">
                <set field="ignoreAccessCheck" from="darpan.facade.common.PilotAccessSupport.requireCompanyRecordAccess(ec, schema, 'Schema not found', 'Schema is not available in your active company.')"/>
            </if>
            <if condition="!ec.message.hasError()">
                <service-call name="jsonschema.JsonSchemaServices.flatten#JsonSchema"
                        in-map="[jsonSchemaId: schema?.jsonSchemaId, schemaName: schema?.schemaName]" out-map="flattenResult"/>
                <set field="fieldList" from="flattenResult.fieldList ?: []"/>
                <set field="jsonSchemaString" from="flattenResult.jsonSchemaString"/>
            </if>
            <set field="ok" from="!ec.message.hasError()"/>
            <set field="messages" from="darpan.facade.common.FacadeSupport.getMessages(ec)"/>
            <set field="errors" from="darpan.facade.common.FacadeSupport.getErrors(ec)"/>
        </actions>
    </service>

    <service verb="save" noun="RefinedSchema" allow-remote="true" authenticate="true">
        <description>Save refined schema field rows from editor in darpan-ui.</description>
        <in-parameters>
            <parameter name="jsonSchemaId"/>
            <parameter name="schemaName"/>
            <parameter name="description"/>
            <parameter name="systemEnumId"/>
            <parameter name="fieldList" type="List" required="true"/>
        </in-parameters>
        <out-parameters>
            <parameter name="ok" type="Boolean"/>
            <parameter name="messages"><parameter name="message"/></parameter>
            <parameter name="errors"><parameter name="error"/></parameter>
            <parameter name="savedSchema">
                <parameter name="jsonSchemaId"/>
                <parameter name="schemaName"/>
                <parameter name="filename"/>
                <parameter name="systemEnumId"/>
                <parameter name="systemLabel"/>
                <parameter name="companyUserGroupId"/>
                <parameter name="createdByUserId"/>
                <parameter name="lastUpdatedStamp" type="Timestamp"/>
            </parameter>
        </out-parameters>
        <actions>
            <set field="schemaIdValue" from="darpan.facade.common.FacadeSupport.normalize(jsonSchemaId)"/>
            <set field="schemaNameValue" from="darpan.facade.common.FacadeSupport.normalize(schemaName)"/>
            <set field="descriptionValue" from="description != null ? darpan.facade.common.FacadeSupport.normalize(description) : null"/>
            <set field="requestedSystemEnumIdValue" from="systemEnumId != null ? darpan.facade.common.FacadeSupport.normalize(systemEnumId) : null"/>
            <set field="ignoreTableEnsure" from="jsonschema.common.JsonSchemaUtil.ensureJsonSchemaTable(ec)"/>
            <if condition="!(fieldList instanceof Collection) || ((Collection) fieldList).isEmpty()">
                <message error="true">fieldList is required and cannot be empty</message>
            </if>
            <if condition="!ec.message.hasError() &amp;&amp; schemaIdValue">
                <set field="schema" from="ec.entity.find('darpan.reconciliation.JsonSchema').condition('jsonSchemaId', schemaIdValue).useCache(false).one()"/>
            </if>
            <if condition="!ec.message.hasError() &amp;&amp; !schema &amp;&amp; schemaNameValue">
                <set field="schema" from="ec.entity.find('darpan.reconciliation.JsonSchema').condition('schemaName', schemaNameValue).useCache(false).one()"/>
            </if>
            <if condition="!ec.message.hasError() &amp;&amp; (schemaIdValue || schemaNameValue)">
                <set field="ignoreAccessCheck" from="darpan.facade.common.PilotAccessSupport.requireCompanyRecordAccess(ec, schema, 'Schema not found', 'Schema is not available in your active company.')"/>
            </if>
            <if condition="!ec.message.hasError()">
                <service-call name="jsonschema.JsonSchemaServices.save#RefinedSchema"
                        in-map="[jsonSchemaId: schemaIdValue, schemaName: schemaNameValue, description: descriptionValue, systemEnumId: requestedSystemEnumIdValue, fieldList: fieldList]" out-map="saveResult"/>
            </if>
            <if condition="!ec.message.hasError()">
                <set field="savedSchemaEntity" from="ec.entity.find('darpan.reconciliation.JsonSchema').condition('jsonSchemaId', saveResult.jsonSchemaId).useCache(false).one()"/>
                <if condition="savedSchemaEntity != null &amp;&amp; !darpan.facade.common.PilotAccessSupport.isSuperAdmin(ec) &amp;&amp; !savedSchemaEntity.companyUserGroupId">
                    <set field="ignoreCompanyAssignment" from="darpan.facade.common.PilotAccessSupport.assignCompanyOwnershipOnCreate(savedSchemaEntity, ec)"/>
                    <if condition="!ec.message.hasError()">
                        <set field="ignoreSavedUpdate" from="savedSchemaEntity.update()"/>
                    </if>
                </if>
                <set field="savedSystemEnumId" from="darpan.facade.common.FacadeSupport.normalize(savedSchemaEntity?.systemEnumId)"/>
                <set field="savedSchema" from="[jsonSchemaId: saveResult.jsonSchemaId, schemaName: saveResult.schemaName, filename: saveResult.filename, systemEnumId: savedSystemEnumId, systemLabel: jsonschema.common.JsonSchemaUtil.resolveSystemLabel(ec, savedSystemEnumId, null, true), companyUserGroupId: savedSchemaEntity?.companyUserGroupId, createdByUserId: savedSchemaEntity?.createdByUserId, lastUpdatedStamp: savedSchemaEntity?.lastUpdatedStamp]"/>
                <message>Saved refined schema ${saveResult.schemaName}.</message>
            </if>
            <set field="ok" from="!ec.message.hasError()"/>
            <set field="messages" from="darpan.facade.common.FacadeSupport.getMessages(ec)"/>
            <set field="errors" from="darpan.facade.common.FacadeSupport.getErrors(ec)"/>
        </actions>
    </service>

    <service verb="delete" noun="JsonSchema" allow-remote="true" authenticate="true">
        <description>Delete a saved JSON schema by id or schemaName.</description>
        <in-parameters>
            <parameter name="jsonSchemaId"/>
            <parameter name="schemaName"/>
        </in-parameters>
        <out-parameters>
            <parameter name="ok" type="Boolean"/>
            <parameter name="messages"><parameter name="message"/></parameter>
            <parameter name="errors"><parameter name="error"/></parameter>
            <parameter name="deleted" type="Boolean"/>
        </out-parameters>
        <actions>
            <set field="jsonSchemaIdValue" from="darpan.facade.common.FacadeSupport.normalize(jsonSchemaId)"/>
            <set field="schemaNameValue" from="darpan.facade.common.FacadeSupport.normalize(schemaName)"/>
            <if condition="!jsonSchemaIdValue &amp;&amp; !schemaNameValue">
                <message error="true">jsonSchemaId or schemaName is required</message>
            </if>
            <if condition="!ec.message.hasError() &amp;&amp; jsonSchemaIdValue">
                <set field="schema" from="ec.entity.find('darpan.reconciliation.JsonSchema').condition('jsonSchemaId', jsonSchemaIdValue).useCache(false).one()"/>
            </if>
            <if condition="!ec.message.hasError() &amp;&amp; !schema &amp;&amp; schemaNameValue">
                <set field="schema" from="ec.entity.find('darpan.reconciliation.JsonSchema').condition('schemaName', schemaNameValue).useCache(false).one()"/>
            </if>
            <if condition="!ec.message.hasError()">
                <set field="ignoreAccessCheck" from="darpan.facade.common.PilotAccessSupport.requireCompanyRecordAccess(ec, schema, 'Schema not found', 'Schema is not available in your active company.')"/>
            </if>
            <if condition="!ec.message.hasError()">
                <service-call name="jsonschema.JsonSchemaServices.delete#JsonSchema"
                        in-map="[jsonSchemaId: schema?.jsonSchemaId, schemaName: schema?.schemaName]" out-map="deleteResult"/>
            </if>
            <if condition="!ec.message.hasError()">
                <set field="deleted" from="true"/>
                <message>Schema deleted.</message>
            </if>
            <if condition="ec.message.hasError()">
                <set field="deleted" from="false"/>
            </if>
            <set field="ok" from="!ec.message.hasError()"/>
            <set field="messages" from="darpan.facade.common.FacadeSupport.getMessages(ec)"/>
            <set field="errors" from="darpan.facade.common.FacadeSupport.getErrors(ec)"/>
        </actions>
    </service>
</services>
