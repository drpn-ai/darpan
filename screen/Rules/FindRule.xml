<?xml version="1.0" encoding="UTF-8"?>
<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/xml-screen-3.xsd" default-menu-title="Rule Library">

    <transition name="createRule">
        <default-response url="../RuleWorkspace"/>
    </transition>
    <transition name="editRule">
        <default-response url="../EditRule"/>
    </transition>

    <actions>
        <service-call name="darpan.rule.RuleServices.get#AccessibleRules" out-map="context"/>
    </actions>

    <widgets>
        <container>
            <link url="createRule" text="New Rule" btn-type="primary"/>
        </container>

        <form-list name="RuleList" list="ruleList" skip-form="true">
            <field name="ruleId">
                <header-field title="ID" show-order-by="true"/>
                <default-field>
                    <link url="editRule" text="${ruleId}" parameter-map="[ruleId:ruleId]"/>
                </default-field>
            </field>
            <field name="ruleName">
                <header-field title="Name" show-order-by="true"/>
                <default-field>
                    <display/>
                </default-field>
            </field>
            <field name="packageName">
                <header-field title="Package"/>
                <default-field>
                    <display/>
                </default-field>
            </field>
            <field name="statusId">
                <header-field title="Status"/>
                <default-field>
                    <display/>
                </default-field>
            </field>
            <field name="scopeType">
                <header-field title="Scope"/>
                <default-field>
                    <display/>
                </default-field>
            </field>
            <field name="lastUpdatedDate">
                <header-field title="Last Updated" show-order-by="true"/>
                <default-field>
                    <display/>
                </default-field>
            </field>
            <field name="editLink">
                <default-field title="">
                    <link url="editRule" text="Edit" parameter-map="[ruleId:ruleId]"/>
                </default-field>
            </field>
        </form-list>
    </widgets>
</screen>
