<?xml version="1.0" encoding="UTF-8"?>
<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/service-definition-3.xsd">

    <service verb="create" noun="JsonSchemaFromJson" type="script"
            location="component://darpan/src/main/groovy/darpan/jsonschema/service/crud/createJsonSchemaFromJson.groovy">
        <description>Create a JSON schema from an uploaded JSON file and save it to the DB.</description>
        <in-parameters>
            <parameter name="jsonFile" type="org.apache.commons.fileupload.FileItem" required="true"/>
            <parameter name="schemaName"/>
            <parameter name="description"/>
            <parameter name="overwrite" type="Boolean" default-value="false"/>
            <parameter name="strict" type="Boolean" default-value="false"/>
        </in-parameters>
        <out-parameters>
            <parameter name="jsonSchemaId"/>
            <parameter name="schemaName"/>
            <parameter name="filename"/><!-- Deprecated -->
        </out-parameters>
    </service>

    <service verb="save" noun="JsonSchema">
        <description>Save an uploaded JSON schema file to the DB.</description>
        <in-parameters>
            <parameter name="schemaFile" type="org.apache.commons.fileupload.FileItem" required="true"/>
            <parameter name="schemaName"/>
            <parameter name="description"/>
            <parameter name="overwrite" type="Boolean" default-value="false"/>
        </in-parameters>
        <out-parameters>
            <parameter name="jsonSchemaId"/>
            <parameter name="schemaName"/>
            <parameter name="filename"/><!-- Deprecated -->
        </out-parameters>
        <actions>
            <set field="schemaUpload" from="jsonschema.common.JsonSchemaUtil.readUploadedText(schemaFile, 'schema file')"/>
            <set field="descriptionValue" from="darpan.facade.common.FacadeSupport.normalize(description)"/>
            <set field="overwriteMode" from="darpan.facade.common.FacadeSupport.normalizeBool(overwrite, false)"/>
            <set field="nameToSave" from="darpan.facade.common.FacadeSupport.normalize(schemaName) ?: schemaUpload.fileName"/>
            <set field="displayDescriptionValue" from="descriptionValue ?: nameToSave"/>
            <if condition="schemaUpload.error">
                <message error="true">${schemaUpload.error}</message>
            </if>
            <if condition="!ec.message.hasError()">
                <set field="finalName" from="jsonschema.common.JsonSchemaUtil.generateUniqueSchemaName(ec, nameToSave, overwriteMode)"/>
                <set field="existingSchema" from="ec.entity.find('darpan.reconciliation.JsonSchema').condition('schemaName', finalName).useCache(false).one()"/>
                <if condition="existingSchema != null">
                    <set field="ignoreSchemaText" from="existingSchema.set('schemaText', schemaUpload.text)"/>
                    <if condition="descriptionValue">
                        <set field="ignoreDescription" from="existingSchema.set('description', descriptionValue)"/>
                    </if>
                    <set field="ignoreLastUpdated" from="existingSchema.set('lastUpdatedStamp', ec.user.nowTimestamp)"/>
                    <set field="ignoreSchemaUpdate" from="existingSchema.update()"/>
                    <set field="jsonSchemaId" from="existingSchema.jsonSchemaId"/>
                </if>
                <if condition="existingSchema == null">
                    <service-call name="create#darpan.reconciliation.JsonSchema"
                            in-map="[schemaName: finalName, schemaText: schemaUpload.text, description: displayDescriptionValue, statusId: 'Active']"
                            out-map="createSchemaResult"/>
                    <set field="jsonSchemaId" from="createSchemaResult.jsonSchemaId"/>
                </if>
                <set field="filename" from="finalName"/>
                <set field="schemaName" from="finalName"/>
                <set field="schemaDataManagerLocation" from="jsonschema.common.JsonSchemaUtil.persistSchemaText(ec, finalName, schemaUpload.text)"/>
            </if>
        </actions>
    </service>

    <service verb="update" noun="JsonSchemaText">
        <description>Update an existing JSON schema in the DB.</description>
        <in-parameters>
            <parameter name="jsonSchemaId"/>
            <parameter name="filename"/><!-- Deprecated -->
            <parameter name="schemaName"/>
            <parameter name="jsonText" required="true" allow-html="any"/>
        </in-parameters>
        <out-parameters>
            <parameter name="jsonSchemaId"/>
        </out-parameters>
        <actions>
            <set field="jsonSchemaIdValue" from="darpan.facade.common.FacadeSupport.normalize(jsonSchemaId)"/>
            <set field="schemaNameValue" from="darpan.facade.common.FacadeSupport.normalize(schemaName)"/>
            <set field="filenameValue" from="darpan.facade.common.FacadeSupport.normalize(filename)"/>
            <set field="jsonTextValue" from="darpan.facade.common.FacadeSupport.normalize(jsonText)"/>
            <set field="jsonValidationError" from="jsonschema.common.JsonSchemaUtil.validateJsonText(jsonTextValue, 'jsonText')"/>
            <if condition="!jsonSchemaIdValue &amp;&amp; !schemaNameValue &amp;&amp; !filenameValue">
                <message error="true">jsonSchemaId, schemaName, or filename is required</message>
            </if>
            <if condition="jsonValidationError">
                <message error="true">${jsonValidationError}</message>
            </if>
            <if condition="!ec.message.hasError()">
                <set field="existingSchema" from="jsonschema.common.JsonSchemaUtil.resolveSchemaRecord(ec, jsonSchemaIdValue, schemaNameValue, filenameValue, false)"/>
                <if condition="!existingSchema">
                    <message error="true">Schema not found for ID ${jsonSchemaIdValue} or Name ${schemaNameValue ?: filenameValue}</message>
                </if>
            </if>
            <if condition="!ec.message.hasError()">
                <set field="ignoreSchemaText" from="existingSchema.set('schemaText', jsonTextValue)"/>
                <set field="ignoreLastUpdated" from="existingSchema.set('lastUpdatedStamp', ec.user.nowTimestamp)"/>
                <set field="ignoreSchemaUpdate" from="existingSchema.update()"/>
                <set field="schemaDataManagerLocation" from="jsonschema.common.JsonSchemaUtil.persistSchemaText(ec, existingSchema.schemaName, jsonTextValue)"/>
                <set field="jsonSchemaId" from="existingSchema.jsonSchemaId"/>
            </if>
        </actions>
    </service>


    <service verb="infer" noun="JsonSchema" type="script"
            location="component://darpan/src/main/groovy/darpan/jsonschema/service/processing/inferJsonSchema.groovy">
        <description>Infer a flattened schema structure from a JSON file for the Creation Wizard.</description>
        <in-parameters>
            <parameter name="jsonFile" required="true" type="org.apache.commons.fileupload.FileItem"/>
        </in-parameters>
        <out-parameters>
            <parameter name="resultList" type="List"/>
            <parameter name="jsonSchemaString" allow-html="any"/>
        </out-parameters>
    </service>

    <service verb="save" noun="RefinedSchema" type="script"
            location="component://darpan/src/main/groovy/darpan/jsonschema/service/crud/saveRefinedSchema.groovy">
        <description>Save a schema from the refined field list to DB; schemaName is required when creating a new schema.</description>
        <in-parameters>
            <parameter name="jsonSchemaId" type="String"/>
            <parameter name="schemaName" type="String"/>
            <parameter name="description" type="String"/>
            <parameter name="systemEnumId" type="String"/>
            <parameter name="fieldList" required="true" type="List"/>
        </in-parameters>
        <out-parameters>
            <parameter name="jsonSchemaId"/>
            <parameter name="schemaName"/>
            <parameter name="filename"/><!-- Deprecated -->
        </out-parameters>
    </service>

    <service verb="validate" noun="JsonFileAgainstSchema" type="script"
            location="component://darpan/src/main/groovy/darpan/jsonschema/service/validation/validateJsonFileAgainstSchema.groovy">
        <description>Validate an uploaded JSON file against a saved JSON schema.</description>
        <in-parameters>
            <parameter name="jsonFile" type="org.apache.commons.fileupload.FileItem" required="true"/>
            <parameter name="jsonSchemaId"/>
            <parameter name="filename"/><!-- Deprecated -->
            <parameter name="schemaName"/>
        </in-parameters>
        <out-parameters>
            <parameter name="valid" type="Boolean"/>
            <parameter name="errorCount" type="Integer"/>
            <parameter name="errorMessages" type="List"/>
        </out-parameters>
    </service>
    
    <service verb="validate" noun="JsonLocationAgainstSchema" type="script"
            location="component://darpan/src/main/groovy/darpan/jsonschema/service/validation/validateJsonLocationAgainstSchema.groovy">
        <description>Validate a JSON file location against a saved JSON schema.</description>
        <in-parameters>
            <parameter name="jsonLocation" required="true"/>
            <parameter name="schemaFileName" required="true"/>
        </in-parameters>
        <out-parameters>
            <parameter name="valid" type="Boolean"/>
            <parameter name="errorCount" type="Integer"/>
            <parameter name="errorMessages" type="List"/>
        </out-parameters>
    </service>

    <service verb="resolve" noun="JsonPathForKey" type="script"
            location="component://darpan/src/main/groovy/darpan/jsonschema/service/processing/resolveJsonPathForKey.groovy">
        <description>Resolve a JSONPath from a key using a saved JSON schema.</description>
        <in-parameters>
            <parameter name="jsonSchemaId"/>
            <parameter name="schemaFileName"/> <!-- Valid filename or schemaName -->
            <parameter name="filename"/> <!-- Deprecated -->
            <parameter name="schemaName"/> 
            <parameter name="key" required="true"/>
        </in-parameters>
        <out-parameters>
            <parameter name="resolvedJsonPath"/>
            <parameter name="matchingPaths"><parameter name="jsonPath"/></parameter>
            <parameter name="found" type="Boolean"/>
        </out-parameters>
    </service>
    <service verb="delete" noun="JsonSchema">
        <description>Delete a JSON schema from DB.</description>
        <in-parameters>
            <parameter name="jsonSchemaId"/>
            <parameter name="filename"/> <!-- Deprecated -->
            <parameter name="schemaName"/>
            <parameter name="schemaFileName"/> <!-- Deprecated -->
        </in-parameters>
        <actions>
            <set field="jsonSchemaIdValue" from="darpan.facade.common.FacadeSupport.normalize(jsonSchemaId)"/>
            <set field="schemaNameValue" from="darpan.facade.common.FacadeSupport.normalize(schemaName ?: filename ?: schemaFileName)"/>
            <if condition="!jsonSchemaIdValue &amp;&amp; !schemaNameValue">
                <message error="true">Schema ID or filename is required</message>
            </if>
            <if condition="!ec.message.hasError() &amp;&amp; jsonSchemaIdValue">
                <set field="schema" from="ec.entity.find('darpan.reconciliation.JsonSchema').condition('jsonSchemaId', jsonSchemaIdValue).one()"/>
            </if>
            <if condition="!ec.message.hasError() &amp;&amp; !schema &amp;&amp; schemaNameValue">
                <set field="schema" from="ec.entity.find('darpan.reconciliation.JsonSchema').condition('schemaName', schemaNameValue).one()"/>
            </if>
            <if condition="!ec.message.hasError()">
                <set field="ignoredDelete" from="jsonschema.common.JsonSchemaUtil.deleteSchemaRecord(ec, schema)"/>
            </if>
        </actions>
    </service>

    <service verb="flatten" noun="JsonSchema" type="script" authenticate="false"
            location="component://darpan/src/main/groovy/darpan/jsonschema/service/processing/flattenJsonSchema.groovy">
        <description>Read a JSON schema from DB or file and flatten it into a list of fields.</description>
        <in-parameters>
            <parameter name="jsonSchemaId"/>
            <parameter name="filename"/> <!-- Deprecated -->
            <parameter name="schemaName"/>
            <parameter name="schemaFile" type="org.apache.commons.fileupload.FileItem"/>
            <parameter name="schemaFileName"/> <!-- Kept for backward compatibility if needed -->
        </in-parameters>
        <out-parameters>
            <parameter name="fieldList" type="List"/>
            <parameter name="jsonSchemaString" allow-html="any"/>
        </out-parameters>
    </service>

</services>
