<?xml version="1.0" encoding="UTF-8"?>
<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/service-definition-3.xsd">

    <service verb="reconcile" noun="MixedFiles">
        <description>Reconcile a CSV file against a JSON file using the unified comparator.</description>
        <in-parameters>
            <parameter name="file1Location" required="true"/>
            <parameter name="file2Location" required="true"/>
            <parameter name="file1Type" required="true"/>
            <parameter name="file2Type" required="true"/>
            
            <parameter name="csvIdField"/>
            <parameter name="jsonIdField"/>
            <parameter name="jsonSchemaFileName"/>
            
            <parameter name="file1Label"/>
            <parameter name="file2Label"/>
            
            <parameter name="hasHeader" type="Boolean" default-value="true"/>
            
            <parameter name="outputLocation"/>
            <parameter name="outputFileName"/>
            
            <parameter name="sparkMaster"/>
            <parameter name="sparkAppName"/>
        </in-parameters>
        <out-parameters>
            <parameter name="diffLocation"/>
            <parameter name="diffFileName"/>
            <parameter name="differenceCount" type="Long"/>
            <parameter name="onlyInFile1Count" type="Long"/>
            <parameter name="onlyInFile2Count" type="Long"/>
        </out-parameters>
        <actions>
            <if condition="!file1Location || !file2Location">
                <return error="true" message="file1Location and file2Location are required"/>
            </if>

            <set field="file1TypeValue" from="((file1Type)?.toString()?.trim())?.toUpperCase()"/>
            <set field="file2TypeValue" from="((file2Type)?.toString()?.trim())?.toUpperCase()"/>
            <if condition="!file1TypeValue || !file2TypeValue">
                <return error="true" message="file1Type and file2Type are required"/>
            </if>
            <set field="file1IdFieldValue" from="file1TypeValue == 'CSV' ? (csvIdField ?: 'id') : null"/>
            <set field="file2IdFieldValue" from="file2TypeValue == 'CSV' ? (csvIdField ?: 'id') : null"/>
            <set field="file1IdExpressionValue" from="file1TypeValue == 'JSON' ? (jsonIdField ?: '$.id') : null"/>
            <set field="file2IdExpressionValue" from="file2TypeValue == 'JSON' ? (jsonIdField ?: '$.id') : null"/>
            <set field="file1SchemaFileNameValue" from="file1TypeValue == 'JSON' ? jsonSchemaFileName : null"/>
            <set field="file2SchemaFileNameValue" from="file2TypeValue == 'JSON' ? jsonSchemaFileName : null"/>

            <service-call name="ReconciliationCoreServices.reconcile#UnifiedFiles"
                    in-map="[file1Location:file1Location, file2Location:file2Location,
                    file1Type:file1TypeValue, file2Type:file2TypeValue,
                    file1IdField:file1IdFieldValue, file2IdField:file2IdFieldValue,
                    file1IdExpression:file1IdExpressionValue, file2IdExpression:file2IdExpressionValue,
                    file1SchemaFileName:file1SchemaFileNameValue, file2SchemaFileName:file2SchemaFileNameValue,
                    file1Label:file1Label, file2Label:file2Label,
                    hasHeader:hasHeader,
                    outputLocation:outputLocation, outputFileName:outputFileName,
                    sparkMaster:sparkMaster, sparkAppName:sparkAppName]"
                    out-map="unifiedOut"/>

            <set field="diffLocation" from="unifiedOut.diffLocation"/>
            <set field="diffFileName" from="unifiedOut.diffFileName"/>
            <set field="differenceCount" from="unifiedOut.differenceCount"/>
            <set field="onlyInFile1Count" from="unifiedOut.onlyInFile1Count"/>
            <set field="onlyInFile2Count" from="unifiedOut.onlyInFile2Count"/>
        </actions>
    </service>

</services>
