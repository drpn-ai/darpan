<?xml version="1.0" encoding="UTF-8"?>
<entities xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/entity-definition-3.xsd">

    <!-- ========================================================= -->
    <!-- darpan.reconciliation -->
    <!-- ========================================================= -->

    <entity entity-name="Reconciliation" package="darpan.reconciliation" use="configuration">
        <description>Schedulable grouping of reconciliation runs.</description>
        <field name="reconciliationId" type="id" is-pk="true"/>
        <field name="reconciliationName" type="text-medium"/>
        <field name="description" type="text-medium"/>
        <field name="scheduleExpr" type="text-medium"/>
        <field name="isActive" type="text-indicator"/>

        <relationship type="many" related="darpan.reconciliation.ReconciliationRun" short-alias="runs">
            <key-map field-name="reconciliationId"/>
        </relationship>
    </entity>

    <entity entity-name="ReconciliationRun" package="darpan.reconciliation" use="configuration">
        <description>Atomic reconciliation check within a reconciliation.</description>
        <field name="reconciliationRunId" type="id" is-pk="true"/>
        <field name="reconciliationId" type="id"/>
        <field name="runName" type="text-medium"/>
        <field name="dataDomain" type="text-short"/>
        <field name="purpose" type="text-short"/>
        <field name="defaultTimeWindow" type="text-short"/>
        <field name="ruleSetId" type="id"/>
        <field name="runSequence" type="number-integer"/>

        <relationship type="one" related="darpan.reconciliation.Reconciliation">
            <key-map field-name="reconciliationId"/>
        </relationship>
        <relationship type="one" related="darpan.rule.RuleSet">
            <key-map field-name="ruleSetId"/>
        </relationship>
        <relationship type="many" related="darpan.reconciliation.RunDataDocument" short-alias="dataDocuments">
            <key-map field-name="reconciliationRunId"/>
        </relationship>
        <relationship type="many" related="darpan.reconciliation.RunSystemInstance" short-alias="systemInstances">
            <key-map field-name="reconciliationRunId"/>
        </relationship>
    </entity>

    <entity entity-name="ReconciliationRunResult" package="darpan.reconciliation" use="transactional" cache="never">
        <description>Persisted artifact manifest for one reconciliation run execution.</description>
        <field name="reconciliationRunResultId" type="id" is-pk="true"/>
        <field name="savedRunId" type="id"/>
        <field name="savedRunType" type="text-short"/>
        <field name="reconciliationRunId" type="id"/>
        <field name="reconciliationMappingId" type="id"/>
        <field name="ruleSetId" type="id"/>
        <field name="compareScopeId" type="id"/>
        <field name="companyUserGroupId" type="id"/>
        <field name="createdByUserId" type="id"/>
        <field name="file1Name" type="text-medium"/>
        <field name="file1DataManagerPath" type="text-long"/>
        <field name="file2Name" type="text-medium"/>
        <field name="file2DataManagerPath" type="text-long"/>
        <field name="resultDataManagerPath" type="text-long"/>
        <field name="statusEnumId" type="id" default="'AUT_STAT_SUCCESS'"/>
        <field name="reconciliationType" type="text-short"/>
        <field name="differenceCount" type="number-integer"/>
        <field name="onlyInFile1Count" type="number-integer"/>
        <field name="onlyInFile2Count" type="number-integer"/>
        <field name="createdDate" type="date-time"/>
        <field name="startedDate" type="date-time"/>
        <field name="completedDate" type="date-time"/>
        <field name="lastUpdatedDate" type="date-time"/>

        <relationship type="one" related="darpan.reconciliation.ReconciliationRun" fk-name="RECRES_RUN">
            <key-map field-name="reconciliationRunId"/>
        </relationship>
        <relationship type="one" related="darpan.mapping.ReconciliationMapping" fk-name="RECRES_MAPPING">
            <key-map field-name="reconciliationMappingId"/>
        </relationship>
        <relationship type="one" related="darpan.rule.RuleSet" fk-name="RECRES_RULESET">
            <key-map field-name="ruleSetId"/>
        </relationship>
        <relationship type="one" related="darpan.rule.RuleSetCompareScope" fk-name="RECRES_SCOPE">
            <key-map field-name="compareScopeId"/>
        </relationship>
        <relationship type="one" title="Company" related="moqui.security.UserGroup" fk-name="RECRES_COMPANY">
            <key-map field-name="companyUserGroupId" related-field-name="userGroupId"/>
        </relationship>
        <relationship type="one" title="CreatedBy" related="moqui.security.UserAccount" fk-name="RECRES_CREATED_BY">
            <key-map field-name="createdByUserId" related-field-name="userId"/>
        </relationship>
        <relationship type="one" title="Status" related="moqui.basic.Enumeration" fk-name="RECRES_STATUS">
            <key-map field-name="statusEnumId" related-field-name="enumId"/>
        </relationship>
    </entity>

    <entity entity-name="TenantNotificationSetting" package="darpan.reconciliation" use="configuration">
        <description>Tenant-level notification settings for reconciliation run completion events.</description>
        <field name="companyUserGroupId" type="id" is-pk="true" not-null="true"/>
        <field name="createdByUserId" type="id"/>
        <field name="googleChatWebhookUrl" type="text-very-long" encrypt="true">
            <description>Google Chat incoming webhook URL. Treat as a secret and never return raw in facade responses.</description>
        </field>
        <field name="isActive" type="text-indicator" default="'Y'"/>
        <field name="createdDate" type="date-time"/>
        <field name="lastUpdatedDate" type="date-time"/>

        <relationship type="one" title="Company" related="moqui.security.UserGroup" fk-name="TENNTF_COMPANY">
            <key-map field-name="companyUserGroupId" related-field-name="userGroupId"/>
        </relationship>
        <relationship type="one" title="CreatedBy" related="moqui.security.UserAccount" fk-name="TENNTF_CREATED_BY">
            <key-map field-name="createdByUserId" related-field-name="userId"/>
        </relationship>
    </entity>

    <entity entity-name="ReconciliationAutomation" package="darpan.reconciliation" use="configuration">
        <description>Tenant-owned automation configuration for scheduled API extraction or SFTP polling against a saved reconciliation run.</description>
        <field name="automationId" type="id" is-pk="true"/>
        <field name="automationName" type="text-medium" not-null="true"/>
        <field name="description" type="text-long"/>
        <field name="companyUserGroupId" type="id" not-null="true"/>
        <field name="createdByUserId" type="id"/>
        <field name="inputModeEnumId" type="id" not-null="true"/>
        <field name="savedRunId" type="id" not-null="true">
            <description>Saved run identifier selected by the operator. For RuleSet-backed saved runs this matches ruleSetId.</description>
        </field>
        <field name="savedRunType" type="text-short" default="'ruleset'"/>
        <field name="reconciliationRunId" type="id">
            <description>Optional legacy ReconciliationRun configuration reference.</description>
        </field>
        <field name="reconciliationMappingId" type="id">
            <description>Optional mapping-backed saved run reference retained for migration compatibility.</description>
        </field>
        <field name="ruleSetId" type="id">
            <description>RuleSet-backed saved run reference used by the automation execution path.</description>
        </field>
        <field name="compareScopeId" type="id">
            <description>RuleSet compare scope selected for this automation.</description>
        </field>
        <field name="scheduleExpr" type="text-medium"/>
        <field name="nextScheduledFireTime" type="date-time">
            <description>Next scheduled fire time used by the automation scanner.</description>
        </field>
        <field name="lastScheduledFireTime" type="date-time">
            <description>Most recent scheduled fire time handed to the automation executor.</description>
        </field>
        <field name="relativeWindowTypeEnumId" type="id"/>
        <field name="relativeWindowCount" type="number-integer"/>
        <field name="customWindowStartDate" type="date-time"/>
        <field name="customWindowEndDate" type="date-time"/>
        <field name="maxWindowDays" type="number-integer" default="28"/>
        <field name="splitWindowDays" type="number-integer" default="28"/>
        <field name="windowTimeZone" type="text-short" default="'UTC'"/>
        <field name="safeConfigJson" type="text-long">
            <description>Non-secret automation metadata safe to show in diagnostics.</description>
        </field>
        <field name="isActive" type="text-indicator" default="'Y'"/>
        <field name="createdDate" type="date-time"/>
        <field name="lastUpdatedDate" type="date-time"/>

        <relationship type="one" title="Company" related="moqui.security.UserGroup" fk-name="RECAUT_COMPANY">
            <key-map field-name="companyUserGroupId" related-field-name="userGroupId"/>
        </relationship>
        <relationship type="one" title="CreatedBy" related="moqui.security.UserAccount" fk-name="RECAUT_CREATED_BY">
            <key-map field-name="createdByUserId" related-field-name="userId"/>
        </relationship>
        <relationship type="one" title="InputMode" related="moqui.basic.Enumeration" fk-name="RECAUT_INPUT_MODE">
            <key-map field-name="inputModeEnumId" related-field-name="enumId"/>
        </relationship>
        <relationship type="one" title="RelativeWindow" related="moqui.basic.Enumeration" fk-name="RECAUT_WINDOW">
            <key-map field-name="relativeWindowTypeEnumId" related-field-name="enumId"/>
        </relationship>
        <relationship type="one" related="darpan.reconciliation.ReconciliationRun" fk-name="RECAUT_RUN">
            <key-map field-name="reconciliationRunId"/>
        </relationship>
        <relationship type="one" related="darpan.mapping.ReconciliationMapping" fk-name="RECAUT_MAPPING">
            <key-map field-name="reconciliationMappingId"/>
        </relationship>
        <relationship type="one" related="darpan.rule.RuleSet" fk-name="RECAUT_RULESET">
            <key-map field-name="ruleSetId"/>
        </relationship>
        <relationship type="one" related="darpan.rule.RuleSetCompareScope" fk-name="RECAUT_SCOPE">
            <key-map field-name="compareScopeId"/>
        </relationship>
        <relationship type="many" related="darpan.reconciliation.ReconciliationAutomationSource" short-alias="sources">
            <key-map field-name="automationId"/>
        </relationship>
        <relationship type="many" related="darpan.reconciliation.ReconciliationAutomationExecution" short-alias="executions">
            <key-map field-name="automationId"/>
        </relationship>
        <index name="RECAUT_DUE_SCAN">
            <index-field name="isActive"/>
            <index-field name="nextScheduledFireTime"/>
        </index>
    </entity>

    <entity entity-name="ReconciliationAutomationSource" package="darpan.reconciliation" use="configuration">
        <description>One FILE_1 or FILE_2 input source definition for an automation.</description>
        <field name="automationId" type="id" is-pk="true" not-null="true"/>
        <field name="fileSide" type="text-short" is-pk="true" not-null="true">
            <description>Logical file side for the automation source: FILE_1 or FILE_2.</description>
        </field>
        <field name="companyUserGroupId" type="id" not-null="true"/>
        <field name="createdByUserId" type="id"/>
        <field name="sourceTypeEnumId" type="id" not-null="true"/>
        <field name="systemEnumId" type="id"/>
        <field name="fileTypeEnumId" type="id"/>
        <field name="schemaFileName" type="text-medium"/>
        <field name="recordRootExpression" type="text-medium"/>
        <field name="primaryIdExpression" type="text-medium"/>
        <field name="idValueNormalizer" type="text-short"/>
        <field name="systemMessageRemoteId" type="id"/>
        <field name="nsRestletConfigId" type="id"/>
        <field name="sftpServerId" type="id"/>
        <field name="remotePathTemplate" type="text-long"/>
        <field name="fileNamePattern" type="text-medium"/>
        <field name="apiRequestTemplateJson" type="text-long"/>
        <field name="apiResponsePathExpression" type="text-medium"/>
        <field name="dateFromParameterName" type="text-short"/>
        <field name="dateToParameterName" type="text-short"/>
        <field name="safeMetadataJson" type="text-long">
            <description>Non-secret source metadata safe to show in diagnostics.</description>
        </field>
        <field name="createdDate" type="date-time"/>
        <field name="lastUpdatedDate" type="date-time"/>

        <relationship type="one" related="darpan.reconciliation.ReconciliationAutomation" fk-name="RECAUTSRC_AUT">
            <key-map field-name="automationId"/>
        </relationship>
        <relationship type="one" title="Company" related="moqui.security.UserGroup" fk-name="RECAUTSRC_COMPANY">
            <key-map field-name="companyUserGroupId" related-field-name="userGroupId"/>
        </relationship>
        <relationship type="one" title="CreatedBy" related="moqui.security.UserAccount" fk-name="RECAUTSRC_CREATED_BY">
            <key-map field-name="createdByUserId" related-field-name="userId"/>
        </relationship>
        <relationship type="one" title="SourceType" related="moqui.basic.Enumeration" fk-name="RECAUTSRC_TYPE">
            <key-map field-name="sourceTypeEnumId" related-field-name="enumId"/>
        </relationship>
        <relationship type="one" title="System" related="moqui.basic.Enumeration" fk-name="RECAUTSRC_SYSTEM">
            <key-map field-name="systemEnumId" related-field-name="enumId"/>
        </relationship>
        <relationship type="one" title="FileType" related="moqui.basic.Enumeration" fk-name="RECAUTSRC_FILETYPE">
            <key-map field-name="fileTypeEnumId" related-field-name="enumId"/>
        </relationship>
        <relationship type="one" related="moqui.service.message.SystemMessageRemote" fk-name="RECAUTSRC_REMOTE">
            <key-map field-name="systemMessageRemoteId"/>
        </relationship>
        <relationship type="one" related="darpan.reconciliation.NsRestletConfig" fk-name="RECAUTSRC_NSREST">
            <key-map field-name="nsRestletConfigId"/>
        </relationship>
        <relationship type="one" related="darpan.reconciliation.SftpServer" fk-name="RECAUTSRC_SFTP">
            <key-map field-name="sftpServerId"/>
        </relationship>
    </entity>

    <entity entity-name="ReconciliationAutomationExecution" package="darpan.reconciliation" use="transactional" cache="never">
        <description>Execution record for one scheduled automation run or one child window split from a larger automation request.</description>
        <field name="automationExecutionId" type="id" is-pk="true"/>
        <field name="automationId" type="id" not-null="true"/>
        <field name="companyUserGroupId" type="id" not-null="true"/>
        <field name="createdByUserId" type="id"/>
        <field name="statusEnumId" type="id" not-null="true" default="'AUT_STAT_PENDING'"/>
        <field name="scheduledDate" type="date-time"/>
        <field name="startedDate" type="date-time"/>
        <field name="completedDate" type="date-time"/>
        <field name="parentAutomationExecutionId" type="id"/>
        <field name="childWindowSequenceNum" type="number-integer"/>
        <field name="windowStartDate" type="date-time"/>
        <field name="windowEndDate" type="date-time"/>
        <field name="childWindowStartDate" type="date-time"/>
        <field name="childWindowEndDate" type="date-time"/>
        <field name="file1Name" type="text-medium"/>
        <field name="file1DataManagerPath" type="text-long"/>
        <field name="file2Name" type="text-medium"/>
        <field name="file2DataManagerPath" type="text-long"/>
        <field name="resultFileName" type="text-medium"/>
        <field name="resultDataManagerPath" type="text-long"/>
        <field name="reconciliationRunResultId" type="id"/>
        <field name="file1RecordCount" type="number-integer"/>
        <field name="file2RecordCount" type="number-integer"/>
        <field name="differenceCount" type="number-integer"/>
        <field name="onlyInFile1Count" type="number-integer"/>
        <field name="onlyInFile2Count" type="number-integer"/>
        <field name="safeMetadataJson" type="text-long">
            <description>Non-secret execution metadata safe to show in diagnostics.</description>
        </field>
        <field name="errorMessage" type="text-long"/>
        <field name="errorDetail" type="text-very-long">
            <description>Sanitized error details; do not store credentials or raw request secrets.</description>
        </field>
        <field name="createdDate" type="date-time"/>
        <field name="lastUpdatedDate" type="date-time"/>

        <relationship type="one" related="darpan.reconciliation.ReconciliationAutomation" fk-name="RECAUTEX_AUT">
            <key-map field-name="automationId"/>
        </relationship>
        <relationship type="one" title="Parent" related="darpan.reconciliation.ReconciliationAutomationExecution" fk-name="RECAUTEX_PARENT">
            <key-map field-name="parentAutomationExecutionId" related-field-name="automationExecutionId"/>
        </relationship>
        <relationship type="one" title="Company" related="moqui.security.UserGroup" fk-name="RECAUTEX_COMPANY">
            <key-map field-name="companyUserGroupId" related-field-name="userGroupId"/>
        </relationship>
        <relationship type="one" title="CreatedBy" related="moqui.security.UserAccount" fk-name="RECAUTEX_CREATED_BY">
            <key-map field-name="createdByUserId" related-field-name="userId"/>
        </relationship>
        <relationship type="one" title="Status" related="moqui.basic.Enumeration" fk-name="RECAUTEX_STATUS">
            <key-map field-name="statusEnumId" related-field-name="enumId"/>
        </relationship>
        <relationship type="one" related="darpan.reconciliation.ReconciliationRunResult" fk-name="RECAUTEX_RUN_RESULT">
            <key-map field-name="reconciliationRunResultId"/>
        </relationship>
        <index name="RECAUTEX_IDEMP" unique="true">
            <index-field name="automationId"/>
            <index-field name="scheduledDate"/>
            <index-field name="childWindowStartDate"/>
            <index-field name="childWindowEndDate"/>
        </index>
    </entity>

    <entity entity-name="RunDataDocument" package="darpan.reconciliation" use="configuration">
        <description>Associates DataDocuments with a reconciliation run.</description>
        <field name="reconciliationRunId" type="id" is-pk="true"/>
        <field name="dataDocumentId" type="id" is-pk="true"/>
        <field name="filterExpression" type="text-long"/>
        <field name="aggregation" type="text-medium"/>
        <field name="isRequired" type="text-indicator"/>

        <relationship type="one" related="darpan.reconciliation.ReconciliationRun">
            <key-map field-name="reconciliationRunId"/>
        </relationship>
        <relationship type="one" related="moqui.entity.document.DataDocument">
            <key-map field-name="dataDocumentId"/>
        </relationship>
    </entity>

    <entity entity-name="RunSystemInstance" package="darpan.reconciliation" use="configuration">
        <description>Associates systems with a reconciliation run.</description>
        <field name="reconciliationRunId" type="id" is-pk="true"/>
        <field name="systemMessageRemoteId" type="id" is-pk="true"/>
        <field name="role" type="text-short"/>

        <relationship type="one" related="darpan.reconciliation.ReconciliationRun">
            <key-map field-name="reconciliationRunId"/>
        </relationship>
        <relationship type="one" related="moqui.service.message.SystemMessageRemote">
            <key-map field-name="systemMessageRemoteId"/>
        </relationship>
    </entity>

    <entity entity-name="SftpServer" package="darpan.reconciliation" use="configuration">
        <description>Simple SFTP server configuration for Reconciliation automation.</description>
        <field name="sftpServerId" type="id" is-pk="true"/>
        <field name="description" type="text-medium"/>
        <field name="scopeEnumId" type="id"/>
        <field name="companyUserGroupId" type="id"/>
        <field name="createdByUserId" type="id"/>
        <field name="host" type="text-medium" cannot-be-null="true"/>
        <field name="port" type="number-integer" default="22"/>
        <field name="username" type="text-medium" cannot-be-null="true"/>
        <field name="password" type="text-medium" encrypt="true"/>
        <field name="privateKey" type="text-long" encrypt="true"/>
        <field name="remoteAttributes" type="text-indicator" default="'Y'"/>

        <relationship type="one" title="Company" related="moqui.security.UserGroup">
            <key-map field-name="companyUserGroupId" related-field-name="userGroupId"/>
        </relationship>
        <relationship type="one" title="Scope" related="moqui.basic.Enumeration">
            <key-map field-name="scopeEnumId" related-field-name="enumId"/>
        </relationship>
        <relationship type="many" related="darpan.reconciliation.SftpServerTenantAccess">
            <key-map field-name="sftpServerId"/>
        </relationship>
    </entity>

    <entity entity-name="SftpServerTenantAccess" package="darpan.reconciliation" use="configuration">
        <description>Tenant access assignment for a shared tenant-group SFTP server.</description>
        <field name="sftpServerId" type="id" is-pk="true"/>
        <field name="tenantUserGroupId" type="id" is-pk="true"/>

        <relationship type="one" related="darpan.reconciliation.SftpServer">
            <key-map field-name="sftpServerId"/>
        </relationship>
        <relationship type="one" title="Tenant" related="moqui.security.UserGroup">
            <key-map field-name="tenantUserGroupId" related-field-name="userGroupId"/>
        </relationship>
    </entity>

    <entity entity-name="NsAuthConfig" package="darpan.reconciliation" use="configuration">
        <description>Reusable NetSuite authentication profile shared by one or more endpoint configs.</description>
        <field name="nsAuthConfigId" type="id" is-pk="true"/>
        <field name="description" type="text-medium"/>
        <field name="companyUserGroupId" type="id"/>
        <field name="createdByUserId" type="id"/>
        <field name="authType" type="text-short" default="'NONE'"/>
        <field name="username" type="text-medium"/>
        <field name="password" type="text-medium" encrypt="true"/>
        <field name="apiToken" type="text-long" encrypt="true"/>
        <field name="tokenUrl" type="text-long"/>
        <field name="clientId" type="text-medium"/>
        <field name="certId" type="text-medium"/>
        <field name="privateKeyPem" type="text-long" encrypt="true"/>
        <field name="scope" type="text-medium" default="'restlets rest_webservices'"/>
        <field name="isActive" type="text-indicator" default="'Y'"/>

        <relationship type="one" title="Company" related="moqui.security.UserGroup">
            <key-map field-name="companyUserGroupId" related-field-name="userGroupId"/>
        </relationship>
    </entity>

    <entity entity-name="NsRestletConfig" package="darpan.reconciliation" use="configuration">
        <description>NetSuite Restlet endpoint settings for inventory reconciliation.</description>
        <field name="nsRestletConfigId" type="id" is-pk="true"/>
        <field name="description" type="text-medium"/>
        <field name="companyUserGroupId" type="id"/>
        <field name="createdByUserId" type="id"/>
        <field name="endpointUrl" type="text-long" cannot-be-null="true"/>
        <field name="httpMethod" type="text-short" default="'POST'"/>
        <field name="nsAuthConfigId" type="id"/>
        <field name="headersJson" type="text-long"/>
        <field name="connectTimeoutSeconds" type="number-integer" default="30"/>
        <field name="readTimeoutSeconds" type="number-integer" default="60"/>
        <field name="isActive" type="text-indicator" default="'Y'"/>

        <!-- Legacy auth fields retained for backward compatibility with existing rows -->
        <field name="authType" type="text-short" default="'NONE'"/>
        <field name="username" type="text-medium"/>
        <field name="password" type="text-medium" encrypt="true"/>
        <field name="apiToken" type="text-long" encrypt="true"/>
        <field name="tokenUrl" type="text-long"/>
        <field name="clientId" type="text-medium"/>
        <field name="certId" type="text-medium"/>
        <field name="privateKeyPem" type="text-long" encrypt="true"/>
        <field name="scope" type="text-medium" default="'restlets rest_webservices'"/>

        <relationship type="one" title="Company" related="moqui.security.UserGroup">
            <key-map field-name="companyUserGroupId" related-field-name="userGroupId"/>
        </relationship>
        <relationship type="one" related="darpan.reconciliation.NsAuthConfig">
            <key-map field-name="nsAuthConfigId"/>
        </relationship>
    </entity>

</entities>
