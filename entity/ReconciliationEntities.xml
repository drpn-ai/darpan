<?xml version="1.0" encoding="UTF-8"?>
<entities xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/entity-definition-3.xsd">

    <!-- ========================================================= -->
    <!-- darpan.reconciliation -->
    <!-- ========================================================= -->

    <entity entity-name="Reconciliation" package="darpan.reconciliation" use="configuration">
        <description>Schedulable grouping of reconciliation runs.</description>
        <field name="reconciliationId" type="id" is-pk="true"/>
        <field name="reconciliationName" type="text-medium"/>
        <field name="description" type="text-medium"/>
        <field name="scheduleExpr" type="text-medium"/>
        <field name="isActive" type="text-indicator"/>

        <relationship type="many" related="darpan.reconciliation.ReconciliationRun" short-alias="runs">
            <key-map field-name="reconciliationId"/>
        </relationship>
    </entity>

    <entity entity-name="ReconciliationRun" package="darpan.reconciliation" use="configuration">
        <description>Atomic reconciliation check within a reconciliation.</description>
        <field name="reconciliationRunId" type="id" is-pk="true"/>
        <field name="reconciliationId" type="id"/>
        <field name="runName" type="text-medium"/>
        <field name="dataDomain" type="text-short"/>
        <field name="purpose" type="text-short"/>
        <field name="defaultTimeWindow" type="text-short"/>
        <field name="ruleSetId" type="id"/>
        <field name="runSequence" type="number-integer"/>

        <relationship type="one" related="darpan.reconciliation.Reconciliation">
            <key-map field-name="reconciliationId"/>
        </relationship>
        <relationship type="one" related="darpan.rule.RuleSet">
            <key-map field-name="ruleSetId"/>
        </relationship>
        <relationship type="many" related="darpan.reconciliation.RunDataDocument" short-alias="dataDocuments">
            <key-map field-name="reconciliationRunId"/>
        </relationship>
        <relationship type="many" related="darpan.reconciliation.RunSystemInstance" short-alias="systemInstances">
            <key-map field-name="reconciliationRunId"/>
        </relationship>
    </entity>

    <entity entity-name="RunDataDocument" package="darpan.reconciliation" use="configuration">
        <description>Associates DataDocuments with a reconciliation run.</description>
        <field name="reconciliationRunId" type="id" is-pk="true"/>
        <field name="dataDocumentId" type="id" is-pk="true"/>
        <field name="filterExpression" type="text-long"/>
        <field name="aggregation" type="text-medium"/>
        <field name="isRequired" type="text-indicator"/>

        <relationship type="one" related="darpan.reconciliation.ReconciliationRun">
            <key-map field-name="reconciliationRunId"/>
        </relationship>
        <relationship type="one" related="moqui.entity.document.DataDocument">
            <key-map field-name="dataDocumentId"/>
        </relationship>
    </entity>

    <entity entity-name="RunSystemInstance" package="darpan.reconciliation" use="configuration">
        <description>Associates systems with a reconciliation run.</description>
        <field name="reconciliationRunId" type="id" is-pk="true"/>
        <field name="systemMessageRemoteId" type="id" is-pk="true"/>
        <field name="role" type="text-short"/>

        <relationship type="one" related="darpan.reconciliation.ReconciliationRun">
            <key-map field-name="reconciliationRunId"/>
        </relationship>
        <relationship type="one" related="moqui.service.message.SystemMessageRemote">
            <key-map field-name="systemMessageRemoteId"/>
        </relationship>
    </entity>

    <entity entity-name="SftpServer" package="darpan.reconciliation" use="configuration">
        <description>Simple SFTP server configuration for Reconciliation automation.</description>
        <field name="sftpServerId" type="id" is-pk="true"/>
        <field name="description" type="text-medium"/>
        <field name="companyUserGroupId" type="id"/>
        <field name="createdByUserId" type="id"/>
        <field name="host" type="text-medium" cannot-be-null="true"/>
        <field name="port" type="number-integer" default="22"/>
        <field name="username" type="text-medium" cannot-be-null="true"/>
        <field name="password" type="text-medium" encrypt="true"/>
        <field name="privateKey" type="text-long" encrypt="true"/>
        <field name="remoteAttributes" type="text-indicator" default="'Y'"/>

        <relationship type="one" title="Company" related="moqui.security.UserGroup">
            <key-map field-name="companyUserGroupId" related-field-name="userGroupId"/>
        </relationship>
    </entity>

    <entity entity-name="NsAuthConfig" package="darpan.reconciliation" use="configuration">
        <description>Reusable NetSuite authentication profile shared by one or more endpoint configs.</description>
        <field name="nsAuthConfigId" type="id" is-pk="true"/>
        <field name="description" type="text-medium"/>
        <field name="companyUserGroupId" type="id"/>
        <field name="createdByUserId" type="id"/>
        <field name="authType" type="text-short" default="'NONE'"/>
        <field name="username" type="text-medium"/>
        <field name="password" type="text-medium" encrypt="true"/>
        <field name="apiToken" type="text-long" encrypt="true"/>
        <field name="tokenUrl" type="text-long"/>
        <field name="clientId" type="text-medium"/>
        <field name="certId" type="text-medium"/>
        <field name="privateKeyPem" type="text-long" encrypt="true"/>
        <field name="scope" type="text-medium" default="'restlets rest_webservices'"/>
        <field name="isActive" type="text-indicator" default="'Y'"/>

        <relationship type="one" title="Company" related="moqui.security.UserGroup">
            <key-map field-name="companyUserGroupId" related-field-name="userGroupId"/>
        </relationship>
    </entity>

    <entity entity-name="NsRestletConfig" package="darpan.reconciliation" use="configuration">
        <description>NetSuite Restlet endpoint settings for inventory reconciliation.</description>
        <field name="nsRestletConfigId" type="id" is-pk="true"/>
        <field name="description" type="text-medium"/>
        <field name="companyUserGroupId" type="id"/>
        <field name="createdByUserId" type="id"/>
        <field name="endpointUrl" type="text-long" cannot-be-null="true"/>
        <field name="httpMethod" type="text-short" default="'POST'"/>
        <field name="nsAuthConfigId" type="id"/>
        <field name="headersJson" type="text-long"/>
        <field name="connectTimeoutSeconds" type="number-integer" default="30"/>
        <field name="readTimeoutSeconds" type="number-integer" default="60"/>
        <field name="isActive" type="text-indicator" default="'Y'"/>

        <!-- Legacy auth fields retained for backward compatibility with existing rows -->
        <field name="authType" type="text-short" default="'NONE'"/>
        <field name="username" type="text-medium"/>
        <field name="password" type="text-medium" encrypt="true"/>
        <field name="apiToken" type="text-long" encrypt="true"/>
        <field name="tokenUrl" type="text-long"/>
        <field name="clientId" type="text-medium"/>
        <field name="certId" type="text-medium"/>
        <field name="privateKeyPem" type="text-long" encrypt="true"/>
        <field name="scope" type="text-medium" default="'restlets rest_webservices'"/>

        <relationship type="one" title="Company" related="moqui.security.UserGroup">
            <key-map field-name="companyUserGroupId" related-field-name="userGroupId"/>
        </relationship>
        <relationship type="one" related="darpan.reconciliation.NsAuthConfig">
            <key-map field-name="nsAuthConfigId"/>
        </relationship>
    </entity>

    <entity entity-name="HcReadDbConfig" package="darpan.reconciliation" use="configuration" table-name="READ_DB_CONFIG">
        <description>Read-only external database settings for inventory reconciliation.</description>
        <field name="hcReadDbConfigId" type="id" is-pk="true"/>
        <field name="description" type="text-medium"/>
        <field name="displayName" type="text-medium"/>
        <field name="host" type="text-medium"/>
        <field name="port" type="number-integer" default="3306"/>
        <field name="databaseName" type="text-medium"/>
        <field name="additionalParameters" type="text-long"/>
        <field name="jdbcUrl" type="text-long" cannot-be-null="true"/>
        <field name="username" type="text-medium" cannot-be-null="true"/>
        <field name="password" type="text-medium" encrypt="true"/>
        <field name="dbDriver" type="text-medium" default="com.mysql.cj.jdbc.Driver"/>
        <field name="defaultTableName" type="text-medium" default="inventory_item_detail"/>
        <field name="itemIdColumn" type="text-short" default="product_id"/>
        <field name="locationIdColumn" type="text-short" default="facility_id"/>
        <field name="transactionDateColumn" type="text-short" default="effective_date"/>
        <field name="connectionPropertiesJson" type="text-long"/>
        <field name="isActive" type="text-indicator" default="Y"/>
    </entity>

</entities>
