<?xml version="1.0" encoding="UTF-8" ?>
<moqui-conf xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/moqui-conf-3.xsd">
    <webapp-list>
        <webapp name="webroot">
            <before-request>
                <actions>
                    <script><![CDATA[
                        darpan.facade.common.PilotAccessSupport.syncUserContext(ec)
                    ]]></script>
                </actions>
            </before-request>
            <after-login>
                <actions>
                    <script><![CDATA[
                        darpan.facade.common.PilotAccessSupport.syncUserContext(ec)
                    ]]></script>
                </actions>
            </after-login>
        </webapp>
    </webapp-list>
    <screen-facade>
        <screen location="component://webroot/screen/webroot/apps.xml">
            <subscreens-item name="darpan" menu-title="Darpan" menu-index="50" location="component://darpan/screen/darpan.xml"/>
        </screen>
    </screen-facade>
</moqui-conf>
