<?xml version="1.0" encoding="UTF-8"?>
<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/service-definition-3.xsd">

    <service verb="migrate" noun="MappingsToRuleSetScopes" type="script" authenticate="true"
            location="component://darpan/src/main/groovy/darpan/reconciliation/migration/migrateMappingsToRuleSetScopes.groovy">
        <description>Migrate existing mapping rows and SFTP jobs onto RuleSet compare-scope configuration.</description>
        <in-parameters>
            <parameter name="dryRun" type="Boolean" default-value="true"/>
            <parameter name="reconciliationMappingId"/>
            <parameter name="rewriteSftpJobParams" type="Boolean" default-value="true"/>
        </in-parameters>
        <out-parameters>
            <parameter name="applied" type="Boolean"/>
            <parameter name="mappingsScanned" type="Integer"/>
            <parameter name="ruleSetsCreated" type="Integer"/>
            <parameter name="compareScopesCreated" type="Integer"/>
            <parameter name="sourcesCreated" type="Integer"/>
            <parameter name="jobsUpdated" type="Integer"/>
            <parameter name="warnings" type="List"/>
        </out-parameters>
    </service>

</services>
